---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import ContactCta from "../components/ContactCta.astro";
import Footer from "../components/Footer.astro";

const pageTitle = "Contacto | DosLlavesGestión";
const pageDescription =
  "Contacta con DosLlavesGestión para valorar tu inmueble en Valencia o Castellón. Gestión integral, rentabilidad, alquiler y transformación de activos inmobiliarios.";

const schema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: pageTitle,
  description: pageDescription,
  url: "https://www.dosllavesgestion.com/contacto/",
  mainEntity: {
    "@type": "Organization",
    name: "DosLlavesGestión",
    url: "https://www.dosllavesgestion.com",
    telephone: "+34623512885",
    email: "info@dosllavesgestion.com",
    areaServed: [
      {
        "@type": "AdministrativeArea",
        name: "Valencia"
      },
      {
        "@type": "AdministrativeArea",
        name: "Castellón"
      }
    ]
  }
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath="/contacto/"
>
  <Header />

  <main>
    <section class="contact-page-hero">
      <div class="shell contact-page-hero-inner">
        <p class="eyebrow light">Contacto</p>

        <h1>Hablemos de tu inmueble.</h1>

        <p>
          Cuéntanos dónde está, en qué situación se encuentra y qué quieres conseguir.
          Te orientaremos sobre la mejor ruta: gestión integral, alquiler tradicional,
          habitaciones, reforma o estrategia de rentabilidad.
        </p>

        <div class="contact-page-actions">
          <a href="/#lead-wizard" class="contact-page-btn contact-page-btn-primary">
            Hacer valoración guiada
          </a>

          <a
            href="https://wa.me/34623512885?text=Hola%2C%20quiero%20informaci%C3%B3n%20sobre%20DosLlavesGesti%C3%B3n."
            target="_blank"
            rel="noopener noreferrer"
            class="contact-page-btn contact-page-btn-secondary"
          >
            Escribir por WhatsApp
          </a>
        </div>
      </div>
    </section>

    <ContactCta />
  </main>

  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
</BaseLayout>
