---
const base = import.meta.env.BASE_URL;
---

<footer class="footer">
  <div class="shell footer-inner">
    <div>
      <a class="logo footer-logo" href={base} aria-label="DosLlavesGestión">
        <span>2L</span>
        <strong>DosLlavesGestión</strong>
      </a>

      <p>Transformación, optimización y gestión integral de activos inmobiliarios.</p>
    </div>

    <div class="footer-links">
      <a href={`${base}#lead-wizard`}>Valoración</a>
      <a href={`${base}servicios/gestion-integral-alquiler/`}>Gestión integral</a>
      <a href={`${base}recursos-arrendadores/`}>Recursos gratuitos</a>
      <a href={`${base}quienes-somos/`}>Quiénes somos</a>
      <a href={`${base}contacto/`}>Contacto</a>
      <a
        href="https://www.instagram.com/oscarochando"
        target="_blank"
        rel="noopener noreferrer"
      >
        Instagram
      </a>
    </div>
  </div>

  <div class="shell footer-bottom">
    <p class="footer-copy">
      © 2026 DosLlavesGestión. Todos los derechos reservados.
    </p>

    <p class="footer-credit">
      Web desarrollada por
      <a
        href="https://indexar.es"
        target="_blank"
        rel="noopener noreferrer"
      >
        Indexar
      </a>
    </p>
  </div>
</footer>
