---
import "../styles/global.css";
import "../styles/mobile-fixes.css";
import "../styles/final-responsive-polish.css";
import "../styles/fix-accidental-underlines.css";
import "../styles/landing-system.css";

const {
  title = "DosLlavesGestión | Transformación y gestión integral de activos inmobiliarios",
  description = "Transformamos, optimizamos y gestionamos activos inmobiliarios en Valencia y Castellón para propietarios e inversores que quieren más rentabilidad y menos gestión diaria.",
  canonicalPath = "/",
  ogImage = "/images/oscar-ochando.jpg",
} = Astro.props;

const siteUrl = "https://dosllavesgestion.com";
const canonicalUrl = `${siteUrl}${canonicalPath}`;
const ogImageUrl = ogImage.startsWith("http")
  ? ogImage
  : `${siteUrl}${ogImage}`;

/* DLCMS SEO OVERRIDES */
const __dlcmsCanonicalPath = typeof canonicalPath !== "undefined"
  ? canonicalPath
  : (Astro.props?.canonicalPath || "/");

const __dlcmsNormalizePath = (value) => {
  let path = String(value || "/").split("?")[0].split("#")[0];

  if (!path.startsWith("/")) {
    path = `/${path}`;
  }

  if (!path.endsWith("/")) {
    path = `${path}/`;
  }

  return path;
};

let finalTitle = title;
let finalDescription = description;
let finalRobots = "index, follow, max-image-preview:large";
let finalHeadCode = "";

async function __dlcmsGetSeoData() {
  if (globalThis.__dlcmsSeoCache !== undefined) {
    return globalThis.__dlcmsSeoCache;
  }

  const controller = new AbortController();
  const timeout = setTimeout(() => controller.abort(), 1500);

  try {
    const response = await fetch("https://dosllavesgestion.com/wpback/wp-json/dosllaves/v1/site-seo", {
      headers: { Accept: "application/json" },
      signal: controller.signal,
    });

    clearTimeout(timeout);

    globalThis.__dlcmsSeoCache = response.ok ? await response.json() : null;
    return globalThis.__dlcmsSeoCache;
  } catch (error) {
    clearTimeout(timeout);
    globalThis.__dlcmsSeoCache = null;
    return null;
  }
}

const seoData = await __dlcmsGetSeoData();

if (seoData) {
  const normalizedPath = __dlcmsNormalizePath(__dlcmsCanonicalPath);
  const pageSeo = seoData?.pages?.[normalizedPath];

  if (pageSeo?.title) {
    finalTitle = pageSeo.title;
  }

  if (pageSeo?.description) {
    finalDescription = pageSeo.description;
  }

  if (pageSeo?.robots && pageSeo.robots !== "index,follow") {
    finalRobots = pageSeo.robots;
  }

  finalHeadCode = `${seoData?.global_head_code || ""}
${pageSeo?.head_code || ""}`.trim();
}
/* END DLCMS SEO OVERRIDES */

---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{finalTitle}</title>
    <meta name="description" content={finalDescription} />

    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:locale" content="es_ES" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={finalTitle} />
    <meta property="og:description" content={finalDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="DosLlavesGestión" />
    <meta property="og:image" content={ogImageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={finalTitle} />
    <meta name="twitter:description" content={finalDescription} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Urbanist:wght@400;500;600;700;800&family=Open+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

  
    <meta name="robots" content={finalRobots} />
    {finalHeadCode && <Fragment set:html={finalHeadCode} />}

    <link rel="icon" href="/favicon.webp" type="image/webp" />

  </head>

  <body>
    <slot />

    <script>
      import { initAnimations } from "../scripts/animations";
      import { initSmoothScroll } from "../scripts/smoothScroll";
      import { initHeaderMenu } from "../scripts/headerMenu";

      document.addEventListener("DOMContentLoaded", () => {
        initSmoothScroll();
        initHeaderMenu();
        initAnimations();
      });

      document.addEventListener("astro:page-load", () => {
        initSmoothScroll();
        initHeaderMenu();
        initAnimations();
      });
    </script>
  
  <script is:inline>
    (() => {
      function cleanPhone(value) {
        return String(value || "").replace(/[^\d]/g, "").slice(0, 15);
      }

      function initDosLlavesFormHardening() {
        const phoneInputs = document.querySelectorAll(
          'input[type="tel"], input[name="telefono"], input[name="phone"]'
        );

        phoneInputs.forEach((input) => {
          input.setAttribute("inputmode", "numeric");
          input.setAttribute("pattern", "[0-9]{9,15}");
          input.setAttribute("maxlength", "15");
          input.setAttribute("autocomplete", "tel");

          if (input.dataset.phoneHardening === "true") return;

          input.dataset.phoneHardening = "true";

          input.addEventListener("input", () => {
            const cleaned = cleanPhone(input.value);

            if (input.value !== cleaned) {
              input.value = cleaned;
            }
          });
        });

        document.querySelectorAll("form").forEach((form) => {
          if (form.dataset.phoneSubmitHardening === "true") return;

          form.dataset.phoneSubmitHardening = "true";

          form.addEventListener(
            "submit",
            () => {
              form
                .querySelectorAll('input[type="tel"], input[name="telefono"], input[name="phone"]')
                .forEach((input) => {
                  input.value = cleanPhone(input.value);
                });
            },
            true
          );
        });
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initDosLlavesFormHardening);
      } else {
        initDosLlavesFormHardening();
      }

      document.addEventListener("astro:page-load", initDosLlavesFormHardening);
    })();
  </script>


  <script is:inline>
    (() => {
      const WHATSAPP_PHONE = "34623512885";

      function cleanValue(value) {
        return String(value || "").trim();
      }

      function getCheckedValue(form, name) {
        const checked = form.querySelector(`[name="${name}"]:checked`);
        return checked ? cleanValue(checked.value) : "";
      }

      function getFieldValue(form, names) {
        for (const name of names) {
          const field = form.querySelector(`[name="${name}"]`);

          if (!field) continue;

          if (field.type === "radio" || field.type === "checkbox") {
            const checked = form.querySelector(`[name="${name}"]:checked`);
            if (checked) return cleanValue(checked.value);
            continue;
          }

          return cleanValue(field.value);
        }

        return "";
      }

      function findRelatedForm(link) {
        const directForm = link.closest("form");

        if (directForm) return directForm;

        const wrapper = link.closest(
          ".home-contact-card, .contact-clean-form, .contact-main-section, .home-contact-v2, .contact-clean-page, .lead-wizard-section"
        );

        if (wrapper) {
          const form = wrapper.querySelector("form");
          if (form) return form;
        }

        const forms = Array.from(document.querySelectorAll("form"));

        if (forms.length === 1) return forms[0];

        return null;
      }

      function buildWhatsappMessage(form) {
        const payload = {
          source: getFieldValue(form, ["source"]),
          objetivo: getFieldValue(form, ["objetivo"]) || getCheckedValue(form, "objetivo"),
          situacion: getFieldValue(form, ["situacion"]) || getCheckedValue(form, "situacion"),
          nombre: getFieldValue(form, ["nombre", "name"]),
          telefono: getFieldValue(form, ["telefono", "phone"]),
          email: getFieldValue(form, ["email"]),
          address: getFieldValue(form, ["address", "direccion", "zona"]),
          mensaje: getFieldValue(form, ["mensaje", "message"]),
        };

        const lines = [
          "Hola, quiero información sobre DosLlavesGestión.",
          "",
          payload.source ? `Origen: ${payload.source}` : "",
          payload.objetivo ? `Objetivo: ${payload.objetivo}` : "",
          payload.situacion ? `Situación: ${payload.situacion}` : "",
          payload.nombre ? `Nombre: ${payload.nombre}` : "",
          payload.telefono ? `Teléfono: ${payload.telefono}` : "",
          payload.email ? `Email: ${payload.email}` : "",
          payload.address ? `Zona / Dirección: ${payload.address}` : "",
          payload.mensaje ? `Mensaje: ${payload.mensaje}` : "",
        ].filter(Boolean);

        return lines.join("\n");
      }

      function initWhatsappFormPrefill() {
        document.querySelectorAll('a[href*="wa.me"], a[href*="api.whatsapp.com"]').forEach((link) => {
          if (link.dataset.whatsappPrefillReady === "true") return;

          link.dataset.whatsappPrefillReady = "true";

          link.addEventListener("click", () => {
            const form = findRelatedForm(link);

            if (!form) return;

            const message = buildWhatsappMessage(form);

            link.href = `https://wa.me/${WHATSAPP_PHONE}?text=${encodeURIComponent(message)}`;
          });
        });
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initWhatsappFormPrefill);
      } else {
        initWhatsappFormPrefill();
      }

      document.addEventListener("astro:page-load", initWhatsappFormPrefill);
    })();
  </script>


  <script is:inline>
    (() => {
      function initDosLlavesAntispam() {
        document.querySelectorAll("form").forEach((form) => {
          let startedAt = form.querySelector('input[name="form_started_at"]');

          if (!startedAt) {
            startedAt = document.createElement("input");
            startedAt.type = "hidden";
            startedAt.name = "form_started_at";
            form.appendChild(startedAt);
          }

          if (!startedAt.value) {
            startedAt.value = String(Date.now());
          }

          let honeypot = form.querySelector('input[name="website"]');

          if (!honeypot) {
            honeypot = document.createElement("input");
            honeypot.type = "text";
            honeypot.name = "website";
            honeypot.className = "form-honeypot";
            honeypot.tabIndex = -1;
            honeypot.autocomplete = "off";
            form.appendChild(honeypot);
          }
        });
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initDosLlavesAntispam);
      } else {
        initDosLlavesAntispam();
      }

      document.addEventListener("astro:page-load", initDosLlavesAntispam);
    })();
  </script>

</body>
</html>
