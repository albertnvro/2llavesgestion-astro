---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import "../../styles/service-gestion-integral.css";

import {
  MessageSquareText,
  Wallet,
  Siren,
  Wrench,
  FileText,
  Eye,
  Clock3,
  ShieldCheck,
  LayoutDashboard,
  ArrowRight,
  Check,
} from "@lucide/astro";

const pageTitle = "Gestión integral del alquiler en Valencia y Castellón | DosLlavesGestión";
const pageDescription =
  "Gestión integral del alquiler para propietarios e inversores en Valencia y Castellón. Delegamos inquilinos, cobros, incidencias, mantenimiento, contratos y seguimiento operativo.";

const modules = [
  {
    title: "Inquilinos",
    text: "Atención, comunicación diaria, avisos y seguimiento sin que todo dependa de ti.",
    icon: MessageSquareText,
  },
  {
    title: "Cobros y pagos",
    text: "Control de cobros, seguimiento de pagos, avisos y trazabilidad de la operativa.",
    icon: Wallet,
  },
  {
    title: "Incidencias",
    text: "Recepción, priorización, coordinación técnica y seguimiento hasta resolver.",
    icon: Siren,
  },
  {
    title: "Mantenimiento",
    text: "Técnicos, reparaciones, revisiones, control de calidad y soporte continuo.",
    icon: Wrench,
  },
  {
    title: "Contratos",
    text: "Seguimiento contractual, renovaciones, documentación, salidas y nuevas entradas.",
    icon: FileText,
  },
  {
    title: "Propietario informado",
    text: "Visibilidad real sin tener que estar pendiente de cada llamada o mensaje.",
    icon: Eye,
  },
];

const comparisonRows = [
  {
    factor: "Tiempo dedicado",
    self: "Tú atiendes mensajes, avisos e incidencias.",
    dosllaves: "Operativa delegada con seguimiento.",
  },
  {
    factor: "Incidencias",
    self: "Tú coordinas técnicos y soluciones.",
    dosllaves: "Proceso claro hasta resolver.",
  },
  {
    factor: "Cobros",
    self: "Tú haces el seguimiento.",
    dosllaves: "Seguimiento de pagos y trazabilidad.",
  },
  {
    factor: "Mantenimiento",
    self: "Buscas proveedores y supervisas.",
    dosllaves: "Coordinación y control operativo.",
  },
  {
    factor: "Rotación",
    self: "Cada cambio vuelve a depender de ti.",
    dosllaves: "Menos rotación y mejor continuidad del activo.",
  },
  {
    factor: "Control",
    self: "Información dispersa y decisiones reactivas.",
    dosllaves: "Propietario informado sin absorber los problemas.",
  },
];

const process = [
  {
    step: "01",
    title: "Revisión inicial",
    text: "Analizamos el estado operativo del alquiler: pagos, contrato, incidencias, situación del inquilino y puntos de mejora.",
  },
  {
    step: "02",
    title: "Orden del sistema",
    text: "Definimos canales, prioridades, responsables y forma de seguimiento para que todo tenga criterio.",
  },
  {
    step: "03",
    title: "Gestión diaria",
    text: "Atendemos inquilinos, cobros, incidencias, reparaciones, mantenimiento y movimientos contractuales.",
  },
  {
    step: "04",
    title: "Control para el propietario",
    text: "Mantienes visibilidad sin asumir la problemas del día a día del día a día.",
  },
];

const faqs = [
  {
    question: "¿Qué incluye la gestión integral del alquiler?",
    answer:
      "Incluye atención a inquilinos, incidencias, mantenimiento, coordinación técnica, seguimiento, seguimiento de pagos, control de cobros, comunicación continua, reparaciones, contratos, renovaciones, salidas y nuevas entradas.",
  },
  {
    question: "¿Puedo delegar una vivienda que ya está alquilada?",
    answer:
      "Sí. Podemos revisar la situación actual del inmueble, el contrato, los pagos, las incidencias y la comunicación para asumir la operativa de forma ordenada.",
  },
  {
    question: "¿También gestionáis reparaciones y técnicos?",
    answer:
      "Sí. Coordinamos técnicos, reparaciones, revisiones, incidencias urgentes y mantenimiento continuo, con seguimiento y control de calidad.",
  },
  {
    question: "¿Trabajáis en Valencia y Castellón?",
    answer:
      "Sí. Actuamos principalmente en Valencia y Castellón, valorando cada inmueble según zona, demanda, estado y viabilidad operativa.",
  },
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "@id": "https://www.dosllavesgestion.com/servicios/gestion-integral-alquiler/#service",
      name: "Gestión integral del alquiler",
      serviceType: "Gestión integral de alquileres",
      description: pageDescription,
      provider: {
        "@type": "Organization",
        name: "DosLlavesGestión",
        url: "https://www.dosllavesgestion.com",
      },
      areaServed: [
        { "@type": "AdministrativeArea", name: "Valencia" },
        { "@type": "AdministrativeArea", name: "Castellón" },
      ],
      audience: {
        "@type": "Audience",
        audienceType: "Propietarios e inversores inmobiliarios",
      },
    },
    {
      "@type": "FAQPage",
      "@id": "https://www.dosllavesgestion.com/servicios/gestion-integral-alquiler/#faq",
      mainEntity: faqs.map((faq) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: faq.answer,
        },
      })),
    },
  ],
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath="/servicios/gestion-integral-alquiler/"
>
  <Header />

  <main class="gil-page">
    <section class="gil-hero">
      <div class="shell gil-hero-grid">
        <div class="gil-hero-copy" data-gil-reveal>
          <nav class="gil-breadcrumb" aria-label="Breadcrumb">
            <a href="/">Inicio</a>
            <span>/</span>
            <a href="/#planes">Servicios</a>
            <span>/</span>
            <strong>Gestión integral del alquiler</strong>
          </nav>

          <p class="gil-kicker landing-chip">Valencia y Castellón · Propietarios e inversores</p>

          <h1>Gestión integral del alquiler</h1>

          <p class="gil-lead">
            Delegas la operativa diaria del inmueble sin perder el control:
            inquilinos, cobros, incidencias, mantenimiento, contratos y seguimiento
            bajo un sistema claro, profesional y estable.
          </p>

          <div class="gil-actions">
            <a href="/#contacto" class="gil-btn gil-btn-primary">
              Solicitar valoración gratuita
            </a>

            <a href="/#contacto" class="gil-btn gil-btn-secondary">
              Hablar con nosotros
            </a>
          </div>

          <div class="gil-proof">
            <span><Check size={14} /> Sin operativa diaria</span>
            <span><Check size={14} /> Visión de activo</span>
            <span><Check size={14} /> Seguimiento al propietario</span>
          </div>
        </div>

        <div class="gil-hero-visual" data-gil-reveal>
          <figure class="gil-photo">
            <img
              src="https://images.unsplash.com/photo-1560518883-ce09059eeffa?auto=format&fit=crop&w=1400&q=80"
              alt="Interior de vivienda lista para alquiler gestionado"
              loading="eager"
            />
          </figure>

          <div class="gil-floating-card gil-floating-card-main">
            <small>Operativa activa</small>
            <strong>Incidencia recibida · técnico coordinado · propietario informado</strong>
          </div>

          <div class="gil-floating-card gil-floating-card-soft">
            <small>Objetivo</small>
            <strong>Alquiler bajo control</strong>
          </div>
        </div>
      </div>
    </section>

    <section class="gil-trust-strip">
      <div class="shell gil-trust-grid">
        <article data-gil-reveal>
          <Clock3 size={20} />
          <div>
            <strong>Tiempo recuperado</strong>
            <p>Tu día deja de depender de cada mensaje, reparación o aviso.</p>
          </div>
        </article>

        <article data-gil-reveal>
          <ShieldCheck size={20} />
          <div>
            <strong>Menos problemas</strong>
            <p>Todo pasa por un sistema ordenado, no por improvisación.</p>
          </div>
        </article>

        <article data-gil-reveal>
          <LayoutDashboard size={20} />
          <div>
            <strong>Más control</strong>
            <p>Sabes qué pasa sin asumir la carga operativa diaria.</p>
          </div>
        </article>
      </div>
    </section>

    <section class="gil-section gil-value">
      <div class="shell gil-value-grid">
        <div class="gil-value-copy" data-gil-reveal>
          <p class="gil-kicker dark landing-chip">Qué cambia cuando delegas</p>
          <h2>Tu alquiler deja de interrumpirte y empieza a funcionar con criterio.</h2>
          <p>
            La mayoría de propietarios no tiene un problema de vivienda; tiene un
            problema de tiempo, coordinación y seguimiento. La gestión integral
            convierte ese desgaste en un sistema operativo más claro, previsible y profesional.
          </p>

          <a href="/#contacto" class="gil-text-link">
            Empezar valoración <ArrowRight size={16} />
          </a>
        </div>

        <div class="gil-value-panels">
          <article class="gil-value-panel" data-gil-reveal>
            <span>01</span>
            <strong>Menos carga mental</strong>
            <p>No tienes que responder cada incidencia ni coordinar cada reparación.</p>
          </article>

          <article class="gil-value-panel" data-gil-reveal>
            <span>02</span>
            <strong>Menos rotación</strong>
            <p>El alquiler se gestiona con proceso, no con decisiones aisladas.</p>
          </article>

          <article class="gil-value-panel" data-gil-reveal>
            <span>03</span>
            <strong>Más tranquilidad</strong>
            <p>Mantienes control y visibilidad sin vivir pendiente del inmueble.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="gil-section gil-compare">
      <div class="shell gil-heading" data-gil-reveal>
        <p class="gil-kicker dark landing-chip">Comparativa clara</p>
        <h2>La diferencia se entiende de un vistazo.</h2>
        <p>
          No es lo mismo alquilar por tu cuenta, apoyarte en una gestión parcial
          o delegar de verdad la operativa del inmueble.
        </p>
      </div>

      <div class="shell gil-comparison-wrap" data-gil-reveal>
        <table class="gil-comparison-table">
          <thead>
            <tr>
              <th>Aspecto</th>
              <th>Por tu cuenta</th>
              <th class="gil-dosllaves-head">
                <span class="gil-dosllaves-table-brand">
                  <img src="/images/Logo.png" alt="" aria-hidden="true" />
                  <span>DosLlavesGestión</span>
                </span>
              </th>
            </tr>
          </thead>

          <tbody>
            {comparisonRows.map((row) => (
              <tr>
                <td>{row.factor}</td>
                <td>
                  <span class="gil-table-x">×</span>
                  {row.self}
                </td>
                <td>
                  <span class="gil-table-check">✓</span>
                  {row.dosllaves}
                </td>
              </tr>
            ))}
          </tbody>
        </table>

        <div class="gil-mobile-comparison" aria-label="Comparativa móvil">
          {comparisonRows.map((row) => (
            <article>
              <h3>{row.factor}</h3>

              <div>
                <span>Por tu cuenta</span>
                <p>{row.self}</p>
              </div>

              <div class="is-dosllaves">
                <span>Con DosLlavesGestión</span>
                <p>{row.dosllaves}</p>
              </div>
            </article>
          ))}
        </div>
      </div>

      <div class="shell gil-inline-cta" data-gil-reveal>
        <div>
          <strong>Si ahora lo haces todo tú, probablemente estás pagando con tiempo.</strong>
          <p>La gestión integral convierte llamadas, cobros e incidencias en un proceso.</p>
        </div>

        <a href="/#contacto" class="gil-small-btn gil-small-btn-primary">
          Quiero delegar mi alquiler
        </a>
      </div>
    </section>

    <section class="gil-section gil-modules-section">
      <div class="shell gil-heading gil-heading-left" data-gil-reveal>
        <p class="gil-kicker dark landing-chip">Qué asumimos</p>
        <h2>Todo lo que normalmente acaba ocupando tu día.</h2>
        <p>
          Una estructura clara para propietarios que quieren ingresos recurrentes
          sin cargar con la operativa diaria.
        </p>
      </div>

      <div class="shell gil-modules">
        {modules.map((item) => {
          const Icon = item.icon;

          return (
            <article class="gil-module" data-gil-reveal>
              <div class="gil-module-icon" aria-hidden="true">
                <Icon size={24} strokeWidth={1.9} />
              </div>

              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          );
        })}
      </div>

      <div class="shell gil-inline-cta gil-inline-cta-dark" data-gil-reveal>
        <div>
          <strong>Deja de atender el alquiler como si fuera otro trabajo.</strong>
          <p>Delegamos la operativa diaria para que tú conserves control, no carga.</p>
        </div>

        <div class="gil-inline-actions">
          <a href="/#contacto" class="gil-small-btn gil-small-btn-accent">Solicitar valoración</a>
        </div>
      </div>
    </section>

    <section class="gil-section gil-reform-section">
      <div class="shell gil-reform-grid">
        <div class="gil-reform-media" data-gil-reveal>
          <figure>
            <img
              src="https://images.unsplash.com/photo-1503387762-592deb58ef4e?auto=format&fit=crop&w=1200&q=80"
              alt="Reforma de vivienda enfocada a rentabilidad de alquiler"
              loading="lazy"
            />
          </figure>

          <div class="gil-reform-badge">
            <span>Equipo propio</span>
            <strong>Reformas pensadas para alquilar mejor</strong>
          </div>
        </div>

        <div class="gil-reform-copy" data-gil-reveal>
          <p class="gil-kicker dark landing-chip">Reformas con foco en rentabilidad</p>

          <h2>Si tu vivienda necesita preparación, también podemos resolverlo.</h2>

          <p>
            Contamos con equipo propio de obras para preparar viviendas de alquiler
            con un objetivo claro: conseguir un efecto wow, controlar costes, reducir
            plazos y mejorar la rentabilidad del propietario sin depender únicamente
            de empresas externas.
          </p>

          <ul>
            <li>Mejoras pensadas para alquilar más rápido.</li>
            <li>Acabados visuales que ayudan a destacar la vivienda.</li>
            <li>Inversión más controlada y enfocada al retorno.</li>
            <li>Preparación integral antes de publicar o gestionar el alquiler.</li>
          </ul>

          <a href="/#contacto" class="gil-text-link">
            Quiero valorar reforma y gestión
          </a>
        </div>
      </div>
    </section>


    <section class="gil-section gil-process-section">
      <div class="shell gil-process-grid">
        <div class="gil-process-copy" data-gil-reveal>
          <p class="gil-kicker dark landing-chip">Proceso</p>
          <h2>Un método claro para que el alquiler avance sin depender de ti.</h2>
          <p>
            Ordenamos la situación y asumimos la gestión diaria con seguimiento,
            criterio operativo y una comunicación mucho más limpia.
          </p>

          <a href="/#contacto" class="gil-text-link">
            Quiero delegar mi alquiler <ArrowRight size={16} />
          </a>
        </div>

        <div class="gil-process-list">
          {process.map((item) => (
            <article class="gil-process-item" data-gil-reveal>
              <span>{item.step}</span>
              <div>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="gil-section gil-fit">
      <div class="shell gil-heading" data-gil-reveal>
        <p class="gil-kicker dark landing-chip">Para quién es</p>
        <h2>Especialmente útil si quieres alquilar sin convertirte en gestor.</h2>
      </div>

      <div class="shell gil-fit-grid">
        <article data-gil-reveal>
          <strong>Vives fuera</strong>
          <p>No puedes atender cada incidencia, visita o reparación de forma directa.</p>
        </article>
        <article data-gil-reveal>
          <strong>No tienes tiempo</strong>
          <p>Quieres rentabilidad sin que el alquiler invada tu agenda.</p>
        </article>
        <article data-gil-reveal>
          <strong>Has tenido problemas</strong>
          <p>Buscas más orden, más filtro y una gestión menos improvisada.</p>
        </article>
        <article data-gil-reveal>
          <strong>Piensas como inversor</strong>
          <p>Quieres operar el inmueble como un activo y no solo tenerlo alquilado.</p>
        </article>
      </div>
    </section>

    <section class="gil-section gil-faq" id="faq">
      <div class="shell gil-faq-grid">
        <div data-gil-reveal>
          <p class="gil-kicker dark landing-chip">FAQ</p>
          <h2>Dudas frecuentes antes de delegar.</h2>
        </div>

        <div class="gil-accordion" data-gil-accordion data-gil-reveal>
          {faqs.map((faq, index) => (
            <details open={index === 0}>
              <summary>{faq.question}</summary>
              <p>{faq.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="gil-final">
      <div class="shell gil-final-card" data-gil-reveal>
        <p class="gil-kicker landing-chip">Valoración gratuita</p>
        <h2>¿Quieres saber qué modelo encaja con tu inmueble?</h2>
        <p>
          Empieza por la valoración y te orientamos según la vivienda, su situación
          actual y el objetivo que buscas.
        </p>

        <div class="gil-actions gil-actions-center">
          <a href="/#contacto" class="gil-btn gil-btn-primary">
            Empezar valoración
          </a>

          <a href="/#contacto" class="gil-btn gil-btn-secondary gil-btn-secondary-light">
            Ir a contacto
          </a>
        </div>
      </div>
    </section>

    <div class="gil-sticky-cta">
      <span>Gestión integral del alquiler</span>
      <a href="/#contacto">Valorar inmueble</a>
    </div>
  </main>

  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>

  <script>
    const revealItems = document.querySelectorAll("[data-gil-reveal]");

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add("is-visible");
          observer.unobserve(entry.target);
        });
      },
      { threshold: 0.15 }
    );

    revealItems.forEach((item) => observer.observe(item));

    document.querySelectorAll("[data-gil-accordion]").forEach((accordion) => {
      const items = accordion.querySelectorAll("details");

      items.forEach((item) => {
        item.addEventListener("toggle", () => {
          if (!item.open) return;

          items.forEach((otherItem) => {
            if (otherItem !== item) otherItem.removeAttribute("open");
          });
        });
      });
    });
  </script>
</BaseLayout>
