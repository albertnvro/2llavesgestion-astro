---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const pageTitle = "Calculadora de rentabilidad de alquiler | DosLlavesGestión";
const pageDescription =
  "La calculadora de rentabilidad ahora forma parte del servicio de análisis de rentabilidad inmobiliaria.";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath="/servicios/analisis-rentabilidad/"
>
  <Header />

  <main>
    <section style="padding: 190px 0 90px; background: linear-gradient(180deg, #ffffff, #eef5ff);">
      <div class="shell" style="max-width: 820px; display: grid; gap: 18px; text-align: center;">
        <p class="eyebrow light">Página trasladada</p>

        <h1>La calculadora está ahora dentro del servicio de análisis de rentabilidad.</h1>

        <p style="color: #66758b; font-size: 18px; line-height: 1.7;">
          Hemos integrado la calculadora dentro de una página más completa para inversores
          y propietarios que quieren analizar la rentabilidad de una vivienda.
        </p>

        <a
          href="/servicios/analisis-rentabilidad/"
          style="min-height: 52px; display: inline-flex; align-items: center; justify-content: center; width: max-content; margin-inline: auto; padding: 0 20px; border-radius: 999px; color: white; background: #07111f; text-decoration: none; font-weight: 850;"
        >
          Ir al servicio
        </a>
      </div>
    </section>
  </main>

  <Footer />

  <script>
    window.location.replace("/servicios/analisis-rentabilidad/");
  </script>
</BaseLayout>
