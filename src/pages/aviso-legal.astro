---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/legal-pages.css";

const pageTitle = "Aviso legal | DosLlavesGestión";
const pageDescription = "Aviso legal de DosLlavesGestión.";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath="/aviso-legal/"
>
  <Header />

  <main class="legal-page">
    <section class="legal-hero">
      <div class="shell">
        <article class="legal-card">
          <p class="legal-kicker">Información legal</p>

          <h1>Aviso legal</h1>

          <p class="legal-intro">
            Consulta la información identificativa del titular de la web,
            condiciones de uso, responsabilidades, propiedad intelectual y normativa aplicable.
          </p>

          <div class="legal-content" data-legal-content="legal_notice">
            <div class="legal-placeholder">
              <strong>Contenido pendiente de completar.</strong>
              <span>Contenido legal pendiente de completar.</span>
            </div>
          </div>
        </article>
      </div>
    </section>
  </main>

  <Footer />

  <script>
    async function loadLegalContent() {
      const target = document.querySelector('[data-legal-content="legal_notice"]');

      if (!target) return;

      try {
        const response = await fetch("/wpback/wp-json/dosllaves/v1/site-legal", {
          headers: { Accept: "application/json" },
        });

        if (!response.ok) return;

        const data = await response.json();

        if (data.legal_notice) {
          target.innerHTML = data.legal_notice;
        }
      } catch (error) {
        console.warn(error);
      }
    }

    loadLegalContent();
  </script>
</BaseLayout>
