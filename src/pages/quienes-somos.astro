---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/about-page-premium.css";

import {
  ArrowRight,
  BadgeCheck,
  BarChart3,
  Building2,
  CheckCircle2,
  Eye,
  Handshake,
  Home,
  KeyRound,
  LineChart,
  ShieldCheck,
  Sparkles,
  Target,
  UsersRound,
} from "@lucide/astro";

const pageTitle = "Quiénes somos | DosLlavesGestión";
const pageDescription =
  "Conoce DosLlavesGestión: gestión integral de alquileres, rentabilidad, reformas orientadas a ROI y acompañamiento para propietarios e inversores en Valencia y Castellón.";

const differences = [
  {
    icon: LineChart,
    title: "Pensamos en rentabilidad",
    text: "No miramos la vivienda solo como un piso alquilado, sino como un activo que debe funcionar con números.",
  },
  {
    icon: ShieldCheck,
    title: "Delegas sin perder control",
    text: "El propietario mantiene visibilidad, pero deja de absorber incidencias, llamadas y gestión diaria.",
  },
  {
    icon: Sparkles,
    title: "Preparamos mejor el inmueble",
    text: "Cuando la vivienda lo necesita, conectamos gestión y reforma para mejorar percepción y salida al mercado.",
  },
];

const method = [
  {
    title: "Diagnóstico",
    text: "Analizamos estado, ubicación, demanda, rentabilidad y posibles mejoras.",
  },
  {
    title: "Modelo",
    text: "Definimos si encaja mejor gestión integral, habitaciones, reforma, comercialización o análisis de rentabilidad.",
  },
  {
    title: "Preparación",
    text: "Ordenamos documentación, puesta a punto, estrategia, publicación y selección.",
  },
  {
    title: "Gestión",
    text: "Coordinamos seguimiento, incidencias, mantenimiento, pagos y comunicación.",
  },
];

const values = [
  {
    icon: BarChart3,
    title: "Rentabilidad",
    text: "Buscamos que cada decisión tenga sentido económico para el propietario.",
  },
  {
    icon: Eye,
    title: "Transparencia",
    text: "Información clara, procesos ordenados y comunicación sin ruido.",
  },
  {
    icon: ShieldCheck,
    title: "Tranquilidad",
    text: "Menos improvisación, menos llamadas y más control sobre el inmueble.",
  },
];

const services = [
  "Gestión integral del alquiler",
  "Alquiler por habitaciones",
  "Reformas orientadas a ROI",
  "Comercialización e inquilinos",
  "Análisis de rentabilidad",
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalPath="/quienes-somos/"
>
  <Header />

  <main class="about-premium-page">
    <section class="about-hero">
      <div class="shell about-hero-grid">
        <div class="about-hero-copy">
          <p class="landing-chip">Quiénes somos</p>

          <h1>
            No somos una inmobiliaria tradicional.
            <span>Somos el operador que hace rentable tu activo.</span>
          </h1>

          <p>
            En DosLlavesGestión ayudamos a propietarios e inversores a transformar,
            preparar y gestionar inmuebles para que funcionen como activos rentables,
            con control, criterio y menos carga operativa.
          </p>

          <div class="about-hero-actions">
            <a href="/#contacto" class="about-btn about-btn-primary">
              Valorar mi inmueble
              <ArrowRight size={17} strokeWidth={2.1} />
            </a>

            <a
              href="https://www.instagram.com/oscarochando"
              target="_blank"
              rel="noopener noreferrer"
              class="about-btn about-btn-secondary"
            >
              Ver Instagram de Óscar
            </a>
          </div>

          <div class="about-proof">
            <span><CheckCircle2 size={14} /> Valencia y Castellón</span>
            <span><CheckCircle2 size={14} /> Propietarios</span>
            <span><CheckCircle2 size={14} /> Inversores</span>
          </div>
        </div>

        <figure class="about-hero-image">
          <img
            src="/images/oscar-ochando-2llavesgestion-2.jpeg"
            alt="Óscar Ochando, responsable de DosLlavesGestión"
            width="1200"
            height="900"
            loading="eager"
          />
        </figure>
      </div>
    </section>

    <section class="about-section about-statement">
      <div class="shell about-centered">
        <p class="landing-chip is-soft">Nuestra visión</p>

        <h2>Convertimos viviendas normales en activos más rentables.</h2>

        <p>
          Nuestro trabajo no termina al encontrar un inquilino. Analizamos el inmueble,
          detectamos oportunidades, mejoramos el activo cuando es necesario y nos ocupamos
          de la gestión real: contratos, cobros, incidencias, mantenimiento, entradas,
          salidas y seguimiento.
        </p>
      </div>
    </section>

    <section class="about-section about-difference">
      <div class="shell about-centered">
        <p class="landing-chip is-soft">Qué nos diferencia</p>

        <h2>Pensamos cada inmueble como una inversión, no como un simple piso.</h2>

        <p>
          El objetivo es construir una solución práctica para el propietario: más claridad,
          menos improvisación y una gestión alineada con el rendimiento del activo.
        </p>
      </div>

      <div class="shell about-card-grid about-card-grid-3">
        {differences.map((item) => {
          const Icon = item.icon;

          return (
            <article>
              <div class="about-icon">
                <Icon size={22} strokeWidth={1.9} />
              </div>

              <h3>{item.title}</h3>

              <p>{item.text}</p>
            </article>
          );
        })}
      </div>
    </section>

    <section class="about-section about-oscar">
      <div class="shell about-oscar-grid">
        <figure class="about-oscar-image">
          <img
            src="/images/oscar-ochando-2llavesgestion-2.jpeg"
            alt="Óscar Ochando trabajando en la estrategia de gestión inmobiliaria"
            width="1200"
            height="900"
            loading="lazy"
          />
        </figure>

        <div class="about-oscar-copy">
          <p class="landing-chip is-soft">Óscar Ochando</p>

          <h2>La cara visible de una gestión inmobiliaria más moderna.</h2>

          <p>
            Óscar trabaja la marca personal desde redes sociales para acercar la inversión
            inmobiliaria, la gestión de alquileres y la transformación de activos a propietarios
            que buscan claridad antes de tomar decisiones.
          </p>

          <p>
            Su papel dentro de DosLlavesGestión es conectar estrategia y ejecución:
            entender qué necesita el propietario, detectar el potencial del inmueble y
            convertirlo en un proyecto gestionable, rentable y profesional.
          </p>

          <div class="about-tags">
            <span>Gestión de alquileres</span>
            <span>Rentabilidad</span>
            <span>Reformas ROI</span>
            <span>Alquiler por habitaciones</span>
          </div>

          <a
            href="https://www.instagram.com/oscarochando"
            target="_blank"
            rel="noopener noreferrer"
            class="about-btn about-btn-primary"
          >
            Seguir a Óscar en Instagram
          </a>
        </div>
      </div>
    </section>

    <section class="about-section about-method">
      <div class="shell about-centered">
        <p class="landing-chip is-soft">Método DosLlaves</p>

        <h2>De inmueble sin estrategia a activo inmobiliario operado.</h2>

        <p>
          Un método pensado para propietarios e inversores que quieren resultados
          sin vivir pendientes del día a día.
        </p>
      </div>

      <div class="shell about-method-grid">
        {method.map((item, index) => (
          <article>
            <span>{String(index + 1).padStart(2, "0")}</span>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="about-section about-values">
      <div class="shell about-values-inner">
        <div class="about-centered about-centered-dark">
          <p class="landing-chip is-on-dark">Valores</p>

          <h2>Rentabilidad, transparencia y tranquilidad.</h2>

          <p>
            La web debe transmitir una marca moderna, elegante y premium, pero por encima
            de todo también tiene que expresar qué ofrecemos: criterio, orden y una forma
            profesional de gestionar viviendas.
          </p>
        </div>

        <div class="about-values-grid">
          {values.map((item) => {
            const Icon = item.icon;

            return (
              <article>
                <div class="about-value-icon">
                  <Icon size={22} strokeWidth={1.9} />
                </div>

                <h3>{item.title}</h3>

                <p>{item.text}</p>
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <section class="about-section about-services">
      <div class="shell about-services-grid">
        <div>
          <p class="landing-chip is-soft">Qué hacemos</p>

          <h2>Una estructura pensada para acompañar todo el ciclo del inmueble.</h2>

          <p>
            Desde el análisis inicial hasta la gestión diaria, DosLlavesGestión reúne las
            piezas que normalmente el propietario tendría que coordinar por separado.
          </p>
        </div>

        <div class="about-services-list">
          {services.map((service) => (
            <span>{service}</span>
          ))}
        </div>
      </div>
    </section>

    <section class="about-final">
      <div class="shell about-final-card">
        <p class="landing-chip is-on-dark">Siguiente paso</p>

        <h2>¿Quieres saber qué potencial tiene tu inmueble?</h2>

        <p>
          Empezamos con una valoración. Revisamos tu vivienda, zona y objetivo
          para decirte qué modelo puede tener más sentido.
        </p>

        <div class="about-final-actions">
          <a href="/#contacto" class="about-btn about-btn-primary">
            Empezar valoración
          </a>

          <a
            href="https://wa.me/34623512885?text=Hola%2C%20quiero%20informaci%C3%B3n%20sobre%20DosLlavesGesti%C3%B3n."
            target="_blank"
            rel="noopener noreferrer"
            class="about-btn about-btn-secondary-dark"
          >
            Hablar por WhatsApp
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
