---
import "../styles/header-mega.css";
import {
  KeyRound,
  TrendingUp,
  Hammer,
  BedDouble,
  UserCheck,
} from "@lucide/astro";

const assetBase = import.meta.env.BASE_URL;
const routeBase = "/";

const services = [
  {
    title: "Gestión integral del alquiler",
    text: "Inquilinos, cobros, incidencias y mantenimiento.",
    href: "servicios/gestion-integral-alquiler/",
    label: "Principal",
    featured: true,
    icon: KeyRound,
  },
  {
    title: "Análisis de rentabilidad",
    text: "Detectamos el mejor modelo de explotación.",
    href: "#lead-wizard",
    icon: TrendingUp,
  },
  {
    title: "Reformas orientadas a ROI",
    text: "Transformación del activo con visión inversora.",
    href: "#lead-wizard",
    icon: Hammer,
  },
  {
    title: "Alquiler por habitaciones",
    text: "Optimización de ingresos y ocupación.",
    href: "#lead-wizard",
    icon: BedDouble,
  },
  {
    title: "Comercialización e inquilinos",
    text: "Anuncios, filtros, visitas y selección.",
    href: "#lead-wizard",
    icon: UserCheck,
  },
];
---

<header class="site-header corporate-header dl-header" data-header-version="simple-premium-icons-v1">
  <div class="shell dl-header-shell">
    <div class="dl-header-top">
      <span>Transformación y gestión inmobiliaria en Valencia y Castellón</span>

      <div class="dl-header-top-links">
        <a href="tel:+34623512885">623 512 885</a>
        <a href="mailto:info@dosllavesgestion.com">info@dosllavesgestion.com</a>
        <a
          href="https://www.instagram.com/oscarochando"
          target="_blank"
          rel="noopener noreferrer"
        >
          Instagram
        </a>
      </div>
    </div>

    <div class="dl-header-main">
      <a class="dl-brand" href={routeBase} aria-label="DosLlavesGestión">
        <img
          src={`${assetBase}images/Logo.png`}
          alt="DosLlavesGestión"
          width="220"
          height="64"
        />
      </a>

      <nav class="dl-nav" aria-label="Navegación principal">
        <div class="dl-nav-service">
          <a
            class="dl-nav-link dl-nav-service-trigger"
            href={`${routeBase}servicios/gestion-integral-alquiler/`}
            aria-haspopup="true"
          >
            Servicios

            <svg viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path
                d="M5 8L10 13L15 8"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </a>

          <div class="dl-service-menu" aria-label="Servicios de DosLlavesGestión">
            <div class="dl-service-menu-head">
              <span>Servicios 360º</span>
              <strong>Elige una ruta</strong>
            </div>

            <div class="dl-service-list">
              {services.map((service) => {
                const Icon = service.icon;

                return (
                  <a
                    class:list={[
                      "dl-service-item",
                      { "is-featured": service.featured },
                    ]}
                    href={`${routeBase}${service.href}`}
                  >
                    <span class="dl-service-mark" aria-hidden="true">
                      <Icon size={20} strokeWidth={1.9} />
                    </span>

                    <span class="dl-service-copy">
                      <strong>{service.title}</strong>
                      <small>{service.text}</small>
                    </span>

                    {service.label && (
                      <em>{service.label}</em>
                    )}
                  </a>
                );
              })}
            </div>

            <div class="dl-service-menu-foot">
              <p>No sabes qué servicio encaja con tu inmueble?</p>
              <a href={`${routeBase}#lead-wizard`}>Hacer valoración</a>
            </div>
          </div>
        </div>

        <a class="dl-nav-link" href={`${routeBase}#lead-wizard`}>Valoración</a>
        <a class="dl-nav-link" href={`${routeBase}recursos-arrendadores/`}>Recursos</a>
        <a class="dl-nav-link" href={`${routeBase}quienes-somos/`}>Quiénes somos</a>
        <a class="dl-nav-link" href={`${routeBase}#contacto`}>Contacto</a>
      </nav>

      <div class="dl-header-actions">
        <a
          class="dl-whatsapp"
          href="https://wa.me/34623512885?text=Hola%2C%20tengo%20una%20vivienda%20en%20Valencia%20o%20Castell%C3%B3n%20y%20quiero%20informaci%C3%B3n%20sobre%20la%20gesti%C3%B3n."
          target="_blank"
          rel="noreferrer"
        >
          WhatsApp
        </a>

        <a class="dl-cta" href={`${routeBase}#lead-wizard`}>
          Valoración gratuita
        </a>
      </div>
    </div>
  </div>
</header>
