<section class="section section-dark" id="servicios">
  <div class="shell section-heading section-heading-dark">
    <p class="eyebrow">Servicios</p>
    <h2>Servicios pensados para propietarios.</h2>
    <p>
      Tres caminos claros según lo que quieres conseguir con tu vivienda:
      rentabilidad, estabilidad o cero gestión diaria.
    </p>
  </div>

  <div class="shell services">
    <article class="service-card">
      <span>Más rentabilidad</span>
      <h3>Alquiler por habitaciones</h3>
      <p>
        Optimización de ocupación, rotación, pagos individuales, mantenimiento
        y comunicación.
      </p>
      <a href="#contacto">Valorar mi vivienda</a>
    </article>

    <article class="service-card service-card-featured">
      <span>Más completo</span>
      <h3>Gestión integral del alquiler</h3>
      <p>
        Delegas inquilinos, contratos, cobros, incidencias, mantenimiento y
        comunicación diaria.
      </p>
      <a href="#contacto">Solicitar información</a>
    </article>

    <article class="service-card">
      <span>Más estabilidad</span>
      <h3>Larga estancia</h3>
      <p>
        Para propietarios que priorizan continuidad, menor rotación y una
        administración profesional.
      </p>
      <a href="#contacto">Ver si encaja</a>
    </article>
  </div>
</section>
