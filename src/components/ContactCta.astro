<section class="section contact-section" id="contacto">
  <div class="shell contact-layout">
    <div class="contact-copy reveal">
      <p class="eyebrow dark">Valoración gratuita</p>

      <h2>Empezamos con tu inmueble.</h2>

      <p>
        Cuéntanos dónde está, en qué punto se encuentra y qué quieres conseguir.
        Te diremos qué ruta puede encajar mejor: estabilidad, rentabilidad,
        transformación o gestión integral.
      </p>

      <div class="contact-points">
        <span>Valencia y Castellón</span>
        <span>Propietarios e inversores</span>
        <span>Valoración personalizada</span>
      </div>
    </div>

    <form class="contact-form reveal" id="lead-form">
      <div class="form-options">
        <label class="choice-card">
          <input type="radio" name="necesidad" value="Tengo alquilado mi piso y quiero estabilidad" checked />
          <span>
            <strong>Tengo alquilado mi piso y quiero estabilidad</strong>
            <small>Quiero delegar gestión tradicional, cobros e incidencias.</small>
          </span>
        </label>

        <label class="choice-card">
          <input type="radio" name="necesidad" value="Quiero más rentabilidad pero no tengo tiempo para gestionar" />
          <span>
            <strong>Quiero más rentabilidad, pero no tengo tiempo</strong>
            <small>Necesito una gestión integral delegada.</small>
          </span>
        </label>

        <label class="choice-card">
          <input type="radio" name="necesidad" value="Quiero transformar o preparar mi vivienda" />
          <span>
            <strong>Quiero transformar o preparar mi vivienda</strong>
            <small>Me interesa reforma, amueblado, home staging o mejora de rentabilidad.</small>
          </span>
        </label>

        <label class="choice-card">
          <input type="radio" name="necesidad" value="Soy inversor y busco rentabilidad" />
          <span>
            <strong>Soy inversor y busco rentabilidad</strong>
            <small>Quiero analizar el inmueble como activo.</small>
          </span>
        </label>
      </div>

      <div class="form-grid">
        <label class="field">
          <span>Nombre</span>
          <input name="nombre" type="text" placeholder="Tu nombre" required />
        </label>

        <label class="field">
          <span>Teléfono</span>
          <input name="telefono" type="tel" placeholder="Tu teléfono" required />
        </label>
      </div>

      <label class="field">
        <span>Zona de la vivienda</span>
        <input name="zona" type="text" placeholder="Valencia, Castellón, Mislata, Burjassot..." />
      </label>

      <label class="field">
        <span>Mensaje</span>
        <textarea name="mensaje" placeholder="Cuéntanos brevemente tu caso."></textarea>
      </label>

      <button type="submit">Quiero hablar con DosLlaves</button>

      <p class="form-note">
        No hacemos spam. Te contactamos una vez, hablamos y tú decides.
      </p>
    </form>
  </div>
</section>

<script>
  const form = document.querySelector("#lead-form");

  form?.addEventListener("submit", (event) => {
    event.preventDefault();

    const data = new FormData(form);

    const message = [
      "Hola, quiero una valoración para mi inmueble.",
      "",
      `Necesidad: ${data.get("necesidad") ?? ""}`,
      `Nombre: ${data.get("nombre") ?? ""}`,
      `Teléfono: ${data.get("telefono") ?? ""}`,
      `Zona: ${data.get("zona") ?? ""}`,
      `Mensaje: ${data.get("mensaje") ?? ""}`,
    ].join("\n");

    const url = `https://wa.me/34623512885?text=${encodeURIComponent(message)}`;
    window.open(url, "_blank");
  });
</script>
