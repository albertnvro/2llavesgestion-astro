<section class="home-contact-v2" id="contacto">
  <div class="shell home-contact-inner">
    <div class="home-contact-head reveal">
      <p class="home-contact-kicker">Valoración gratuita</p>

      <h2>Empezamos con tu inmueble.</h2>

      <p>
        Cuéntanos en qué punto está la vivienda y qué quieres conseguir.
        Te orientamos sobre el modelo más adecuado: estabilidad, rentabilidad,
        transformación o gestión integral.
      </p>

      <div class="home-contact-proof" aria-label="Ventajas">
        <span>Valencia y Castellón</span>
        <span>Propietarios e inversores</span>
        <span>Respuesta personalizada</span>
      </div>
    </div>

    <div class="home-contact-card reveal">
      <div class="home-contact-card-head">
        <div>
          <span>Diagnóstico rápido</span>
          <strong>¿Qué necesita ahora tu inmueble?</strong>
        </div>
      </div>

      <form class="home-contact-form" id="home-contact-form">
        <input type="text" name="website" class="home-hp" tabindex="-1" autocomplete="off" />

        <input type="hidden" name="source" value="Home - formulario ancho" />
        <input type="hidden" name="situacion" value="Solicitud desde home" />
        <input type="hidden" name="privacy_accepted_at" id="home-privacy-accepted-at" />

        <fieldset class="home-options">
          <legend>Selecciona la situación que mejor encaja</legend>

          <label class="home-option">
            <input
              type="radio"
              name="objetivo"
              value="Tengo alquilado mi piso y quiero estabilidad"
              checked
            />

            <span class="home-option-dot"></span>

            <span>
              <strong>Tengo alquilado mi piso y quiero estabilidad</strong>
              <small>Quiero delegar gestión tradicional, cobros e incidencias.</small>
            </span>
          </label>

          <label class="home-option">
            <input
              type="radio"
              name="objetivo"
              value="Quiero más rentabilidad pero no tengo tiempo"
            />

            <span class="home-option-dot"></span>

            <span>
              <strong>Quiero más rentabilidad, pero no tengo tiempo</strong>
              <small>Necesito una gestión integral delegada.</small>
            </span>
          </label>

          <label class="home-option">
            <input
              type="radio"
              name="objetivo"
              value="Quiero transformar o preparar mi vivienda"
            />

            <span class="home-option-dot"></span>

            <span>
              <strong>Quiero transformar o preparar mi vivienda</strong>
              <small>Me interesa reforma, amueblado o mejora de rentabilidad.</small>
            </span>
          </label>

          <label class="home-option">
            <input
              type="radio"
              name="objetivo"
              value="Soy inversor y busco rentabilidad"
            />

            <span class="home-option-dot"></span>

            <span>
              <strong>Soy inversor y busco rentabilidad</strong>
              <small>Quiero analizar el inmueble como activo.</small>
            </span>
          </label>
        </fieldset>

        <div class="home-fields">
          <label>
            <span>Nombre</span>
            <input name="nombre" type="text" placeholder="Tu nombre" required />
          </label>

          <label>
            <span>Teléfono</span>
            <input name="telefono" type="tel" placeholder="Tu teléfono" required inputmode="numeric" pattern="[0-9]{9,15}" maxlength="15" autocomplete="tel" />
          </label>

          <label>
            <span>Email</span>
            <input name="email" type="email" placeholder="tu@email.com" required />
          </label>

          <label>
            <span>Zona de la vivienda</span>
            <input
              name="address"
              type="text"
              placeholder="Valencia, Castellón, Mislata, Burjassot..."
              required
            />
          </label>
        </div>

        <label class="home-message">
          <span>Mensaje</span>
          <textarea
            name="mensaje"
            placeholder="Cuéntanos brevemente tu caso."
          ></textarea>
        </label>

        <div class="home-form-bottom">
          <label class="home-privacy">
            <input
              id="home-privacy"
              name="privacy"
              type="checkbox"
              value="Aceptada"
              required
            />

            <span>
              Acepto la
              <a href="/politica-de-privacidad/" target="_blank" rel="noopener noreferrer">
                política de privacidad
              </a>
              y autorizo el tratamiento de mis datos para responder a mi solicitud.
            </span>
          </label>

          <div class="home-submit-wrap">
            <button type="submit">Solicitar valoración</button>

            <a
              href="https://wa.me/34623512885?text=Hola%2C%20quiero%20informaci%C3%B3n%20sobre%20DosLlavesGesti%C3%B3n."
              target="_blank"
              rel="noopener noreferrer"
            >
              WhatsApp
            </a>
          </div>
        </div>

        <p class="home-form-status" id="home-form-status" aria-live="polite"></p>
      </form>
    </div>
  </div>
</section>

<script>
  const homeForm = document.querySelector("#home-contact-form");
  const homeStatus = document.querySelector("#home-form-status");

  function setHomeStatus(message, type = "") {
    if (!homeStatus) return;

    homeStatus.textContent = message;
    homeStatus.classList.remove("is-ok", "is-error");

    if (type) {
      homeStatus.classList.add(type);
    }
  }

  homeForm?.addEventListener("submit", async (event) => {
    event.preventDefault();

    const privacyAcceptedAt = document.querySelector("#home-privacy-accepted-at");

    if (privacyAcceptedAt) {
      privacyAcceptedAt.value = new Date().toISOString();
    }

    if (!homeForm.checkValidity()) {
      homeForm.reportValidity();
      return;
    }

    const data = new FormData(homeForm);

    if (data.get("website")) return;

    const payload = Object.fromEntries(data.entries());

    const endpoint = "/wpback/wp-json/dosllaves/v1/lead";

    let sent = false;

    if (endpoint) {
      try {
        setHomeStatus("Enviando solicitud...");

        const response = await fetch(endpoint, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify(payload),
        });

        sent = response.ok;
      } catch (error) {
        sent = false;
      }
    }

    if (sent) {
      setHomeStatus(
        "Solicitud enviada. Te hemos enviado un email de confirmación y pronto nos pondremos en contacto contigo.",
        "is-ok"
      );

      homeForm.reset();
      return;
    }
    setHomeStatus("No se ha podido enviar la solicitud. Revisa los datos o inténtalo de nuevo. Si lo prefieres, puedes usar el botón de WhatsApp.", "is-error");
});
</script>

