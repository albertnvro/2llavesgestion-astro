<section class="hero">
  <div class="shell hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">Gestión integral de alquileres en Valencia</p>

      <h1>
        Alquila tu vivienda sin
        <span>gestionar problemas.</span>
      </h1>

      <p class="hero-lead">
        Para propietarios que quieren rentabilidad sin llamadas, conflictos ni
        improvisación. Nos ocupamos de inquilinos, contratos, cobros,
        incidencias, mantenimiento y comunicación diaria.
      </p>

      <div class="hero-actions">
        <a class="btn btn-primary" href="#contacto">
          Solicitar valoración gratuita
        </a>

        <a
          class="btn btn-secondary"
          href="https://wa.me/34623512885"
          target="_blank"
          rel="noreferrer"
        >
          Hablar por WhatsApp
        </a>
      </div>

      <div class="pills">
        <span>Alquiler por habitaciones</span>
        <span>Larga estancia</span>
        <span>Gestión diaria</span>
        <span>Valencia y alrededores</span>
      </div>
    </div>

    <div class="hero-visual" aria-hidden="true">
      <div class="control-card">
        <div class="control-top">
          <strong>Rental Control</strong>
          <span>Activo</span>
        </div>

        <div class="control-main">
          <small>Gestión 360º</small>
          <strong>0</strong>
          <p>llamadas de gestión para ti</p>
        </div>

        <div class="control-list">
          <div>
            <span>Inquilinos</span>
            <strong>Filtro y selección</strong>
          </div>
          <div>
            <span>Cobros</span>
            <strong>Seguimiento mensual</strong>
          </div>
          <div>
            <span>Incidencias</span>
            <strong>Mantenimiento coordinado</strong>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
