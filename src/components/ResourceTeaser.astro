---
const base = import.meta.env.BASE_URL;
---

<section class="section resources-teaser" id="recursos">
  <div class="shell resources-teaser-layout">
    <div class="resources-teaser-copy reveal">
      <p class="eyebrow light">Recursos gratuitos</p>

      <h2>Herramientas útiles para arrendadores.</h2>

      <p>
        Cláusulas, checklists y plantillas orientativas para propietarios que quieren
        alquilar con más orden, menos improvisación y mejor criterio.
      </p>
    </div>

    <div class="resources-teaser-card reveal">
      <span>Nuevo</span>
      <h3>Biblioteca gratuita para propietarios</h3>
      <p>
        Accede a recursos que puedes copiar, adaptar y usar como punto de partida
        para tu contrato, inventario o gestión diaria.
      </p>

      <a href={`${base}recursos-arrendadores/`}>
        Ver recursos gratuitos
      </a>
    </div>
  </div>
</section>
