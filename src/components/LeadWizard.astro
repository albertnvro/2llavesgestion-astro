<section class="section lead-wizard-section" id="lead-wizard">
  <div class="shell lead-wizard-header reveal">
    <p class="eyebrow light">Valoración profesional</p>

    <h2>Empieza por la dirección de tu inmueble.</h2>

    <p>
      Con la ubicación podemos orientar mejor la estrategia: zona, tipo de demanda,
      potencial de alquiler tradicional, habitaciones, reforma o gestión integral.
    </p>
  </div>

  <div class="shell lead-wizard reveal">
    <aside class="wizard-sidebar">
      <div class="wizard-progress-rail">
        <span class="wizard-progress-bar"></span>
      </div>

      <div class="wizard-key-end" aria-hidden="true">
        <svg viewBox="0 0 120 120" fill="none">
          <path d="M45 67a24 24 0 1 1 16.8-7.1L99 97.2 86.5 110 76 99.5 66.5 109 55 97.5l9.5-9.5-15.8-15.8A24 24 0 0 1 45 67Z" stroke="currentColor" stroke-width="8" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="45" cy="43" r="8" stroke="currentColor" stroke-width="8"/>
        </svg>
      </div>

      <div class="wizard-step-label is-active" data-label-step="1">
        <span class="wizard-step-dot">01</span>
        <strong>Dirección</strong>
      </div>

      <div class="wizard-step-label" data-label-step="2">
        <span class="wizard-step-dot">02</span>
        <strong>Situación</strong>
      </div>

      <div class="wizard-step-label" data-label-step="3">
        <span class="wizard-step-dot">03</span>
        <strong>Objetivo</strong>
      </div>

      <div class="wizard-step-label" data-label-step="4">
        <span class="wizard-step-dot">04</span>
        <strong>Contacto</strong>
      </div>
    </aside>

    <form class="wizard-form" id="property-lead-form">
      <input type="text" name="website" class="hp-field" tabindex="-1" autocomplete="off" />

      <section class="wizard-panel is-active" data-step="1">
        <div class="wizard-panel-head">
          <span>Primer paso</span>
          <h3>¿Dónde está la vivienda?</h3>
          <p>
            Empieza escribiendo la dirección. Google sugerirá coincidencias reales
            para evitar errores y acelerar la valoración.
          </p>
        </div>

        <div class="address-box">
          <label class="field">
            <span>Dirección de la vivienda</span>
            <input
              id="address-input"
              class="address-input"
              type="text"
              placeholder="Empieza a escribir la dirección..."
              autocomplete="street-address"
            />
            <div class="address-suggestions" id="address-suggestions" hidden></div>
          </label>

          <p class="address-status" id="address-status">
            Escribe una dirección y selecciona una sugerencia.
          </p>
        </div>

        <input type="hidden" name="address" id="lead-address" />
        <input type="hidden" name="place_id" id="lead-place-id" />
        <input type="hidden" name="lat" id="lead-lat" />
        <input type="hidden" name="lng" id="lead-lng" />

        <div class="wizard-actions">
          <button type="button" class="wizard-next" data-next="2">
            Continuar
          </button>
        </div>
      </section>

      <section class="wizard-panel" data-step="2">
        <div class="wizard-panel-head">
          <span>Situación actual</span>
          <h3>¿En qué punto está el inmueble?</h3>
          <p>
            Así distinguimos entre gestión tradicional, gestión delegada,
            transformación del activo o alquiler por habitaciones.
          </p>
        </div>

        <div class="choice-grid" data-choice-group="situacion">
          <button type="button" data-value="Vivienda vacía">Vivienda vacía</button>
          <button type="button" data-value="Ya está alquilada">Ya está alquilada</button>
          <button type="button" data-value="Necesita reforma o preparación">Necesita reforma</button>
          <button type="button" data-value="Quiero valorar habitaciones">Quiero valorar habitaciones</button>
        </div>

        <input type="hidden" name="situacion" id="lead-situacion" />

        <div class="wizard-actions">
          <button type="button" class="wizard-prev" data-prev="1">Atrás</button>
          <button type="button" class="wizard-next" data-next="3">Continuar</button>
        </div>
      </section>

      <section class="wizard-panel" data-step="3">
        <div class="wizard-panel-head">
          <span>Objetivo</span>
          <h3>¿Qué quieres conseguir?</h3>
          <p>
            Esta respuesta nos ayuda a recomendar estabilidad, rentabilidad,
            reforma orientada a ROI o gestión integral delegada.
          </p>
        </div>

        <div class="choice-grid objective-grid" data-choice-group="objetivo">
          <button type="button" data-value="Quiero estabilidad">
            <strong>Estabilidad</strong>
            <small>Gestión tradicional y menos problemas.</small>
          </button>

          <button type="button" data-value="Quiero más rentabilidad">
            <strong>Más rentabilidad</strong>
            <small>Analizar habitaciones, reforma o estrategia.</small>
          </button>

          <button type="button" data-value="Quiero delegarlo todo">
            <strong>Delegarlo todo</strong>
            <small>Gestión integral de principio a fin.</small>
          </button>

          <button type="button" data-value="Soy inversor">
            <strong>Soy inversor</strong>
            <small>Optimizar activo, retorno y operación.</small>
          </button>
        </div>

        <input type="hidden" name="objetivo" id="lead-objetivo" />

        <div class="wizard-actions">
          <button type="button" class="wizard-prev" data-prev="2">Atrás</button>
          <button type="button" class="wizard-next" data-next="4">Continuar</button>
        </div>
      </section>

      <section class="wizard-panel" data-step="4">
        <div class="wizard-panel-head">
          <span>Contacto</span>
          <h3>Te decimos qué ruta encaja mejor.</h3>
          <p>
            Déjanos tus datos y te contactamos con una valoración inicial.
            Sin compromiso.
          </p>
        </div>

        <div class="field-grid">
          <label class="field">
            <span>Nombre</span>
            <input name="nombre" type="text" placeholder="Tu nombre" required />
          </label>

          <label class="field">
            <span>Teléfono</span>
            <input name="telefono" type="tel" placeholder="Tu teléfono" required />
          </label>
        </div>

        <label class="field">
          <span>Email</span>
          <input name="email" type="email" placeholder="tu@email.com" required />
        </label>

        <label class="field">
          <span>Mensaje</span>
          <textarea name="mensaje" placeholder="Cuéntanos brevemente tu caso."></textarea>
        </label>

        <div class="wizard-summary" id="wizard-summary" hidden></div>

<input type="hidden" name="privacy_accepted_at" id="lead-privacy-accepted-at" />

        <label class="privacy-check">
          <input
            id="lead-privacy"
            name="privacy"
            type="checkbox"
            value="Aceptada"
            required
          />

          <span>
            Acepto la
            <a href="/politica-de-privacidad/" target="_blank" rel="noopener noreferrer">
              política de privacidad
            </a>
            y autorizo el tratamiento de mis datos para responder a mi solicitud.
          </span>
        </label>

        <div class="wizard-actions">
          <button type="button" class="wizard-prev" data-prev="3">Atrás</button>
          <button type="submit" class="wizard-submit">Enviar valoración</button>
        </div>

        <p class="form-note">
          Si el envío web todavía no está conectado, se abrirá WhatsApp con los datos.
        </p>
      </section>

      <section class="wizard-panel wizard-success" data-step="success">
        <div class="wizard-panel-head">
          <span>Solicitud enviada</span>
          <h3>Gracias. Ya tenemos los datos de tu inmueble.</h3>
          <p>
            Te hemos enviado un email con el resumen de tu solicitud. Nosotros también
            hemos recibido tus datos y nos pondremos en contacto contigo pronto.
          </p>
        </div>

        <div class="wizard-success-actions">
          <a
            class="wizard-success-link"
            href="https://www.instagram.com/oscarochando"
            target="_blank"
            rel="noopener noreferrer"
          >
            Ver contenido de Óscar en Instagram
          </a>

          <a
            class="wizard-success-link wizard-success-secondary"
            href="/recursos-arrendadores/"
          >
            Ver recursos gratuitos
          </a>
        </div>
      </section>
    </form>
  </div>
</section>

<script>
  import { setOptions, importLibrary } from "@googlemaps/js-api-loader";

  const apiKey = (import.meta.env.PUBLIC_GOOGLE_MAPS_API_KEY || "").trim();

  const lead = {
    address: "",
    placeId: "",
    lat: "",
    lng: "",
    situacion: "",
    objetivo: "",
  };

  const form = document.querySelector("#property-lead-form");
  const addressInput = document.querySelector("#address-input");
  const addressStatus = document.querySelector("#address-status");

  const leadAddress = document.querySelector("#lead-address");
  const leadPlaceId = document.querySelector("#lead-place-id");
  const leadLat = document.querySelector("#lead-lat");
  const leadLng = document.querySelector("#lead-lng");
  const leadSituacion = document.querySelector("#lead-situacion");
  const leadObjetivo = document.querySelector("#lead-objetivo");

  function setStep(step) {
    document.querySelectorAll(".wizard-panel").forEach((panel) => {
      panel.classList.toggle("is-active", panel.getAttribute("data-step") === String(step));
    });

    document.querySelectorAll(".wizard-step-label").forEach((label) => {
      const labelStep = Number(label.getAttribute("data-label-step"));
      label.classList.toggle("is-active", labelStep === Number(step));
      label.classList.toggle("is-complete", labelStep < Number(step));
    });

    const progress = document.querySelector(".wizard-progress-bar");
    const progressValue = step === "success" ? 1 : (Number(step) - 1) / 3;

    if (progress) {
      progress.style.transform = `scaleY(${progressValue})`;
    }

    if (step === 4) {
      updateSummary();
    }
  }

  function updateSummary() {
    const summary = document.querySelector("#wizard-summary");
    if (!summary) return;

    summary.innerHTML = `
      <strong>Resumen de valoración</strong>
      <span>${lead.address || "Dirección pendiente"}</span>
      <span>${lead.situacion || "Situación pendiente"}</span>
      <span>${lead.objetivo || "Objetivo pendiente"}</span>
    `;

    summary.hidden = false;
  }

  function setAddressStatus(message, type = "") {
    if (!addressStatus) return;
    addressStatus.textContent = message;
    addressStatus.classList.remove("is-error", "is-ok");
    if (type) addressStatus.classList.add(type);
  }

  function validateStep(step) {
    if (step === 1) {
      const typedValue =
        addressInput instanceof HTMLInputElement ? addressInput.value.trim() : "";

      if (!lead.address && typedValue) {
        lead.address = typedValue;
        leadAddress.value = typedValue;
      }

      if (!lead.address) {
        setAddressStatus("Introduce o selecciona una dirección para continuar.", "is-error");
        return false;
      }
    }

    if (step === 2 && !lead.situacion) {
      alert("Selecciona la situación actual del inmueble.");
      return false;
    }

    if (step === 3 && !lead.objetivo) {
      alert("Selecciona el objetivo principal.");
      return false;
    }

    return true;
  }

  async function initGoogleAutocomplete() {
    const suggestionsBox = document.querySelector("#address-suggestions");

    console.info("[Google Places debug]", {
      hasApiKey: Boolean(apiKey),
      origin: window.location.origin,
      href: window.location.href,
    });

    window.gm_authFailure = () => {
      console.error("[Google Places] Google ha rechazado la API key", {
        origin: window.location.origin,
        href: window.location.href,
      });

      setAddressStatus(
        "Google ha rechazado la API key. Revisa APIs activas, facturación o restricciones.",
        "is-error"
      );
    };

    if (!(addressInput instanceof HTMLInputElement) || !suggestionsBox) {
      setAddressStatus("No se ha encontrado el campo de dirección.", "is-error");
      return;
    }

    if (!apiKey) {
      setAddressStatus(
        "No se ha detectado la API key. Revisa el archivo .env y reinicia Astro.",
        "is-error"
      );
      return;
    }

    function escapeHtml(value) {
      return String(value)
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function closeSuggestions() {
      suggestionsBox.hidden = true;
      suggestionsBox.innerHTML = "";
    }

    function renderSuggestions(suggestions) {
      if (!suggestions.length) {
        closeSuggestions();
        return;
      }

      suggestionsBox.innerHTML = suggestions
        .map((suggestion, index) => {
          const prediction = suggestion.placePrediction;
          const main =
            prediction?.mainText?.text ||
            prediction?.text?.text ||
            "Dirección sugerida";

          const secondary =
            prediction?.secondaryText?.text ||
            "";

          return `
            <button type="button" class="address-suggestion" data-index="${index}">
              <strong>${escapeHtml(main)}</strong>
              ${secondary ? `<span>${escapeHtml(secondary)}</span>` : ""}
            </button>
          `;
        })
        .join("");

      suggestionsBox.hidden = false;

      suggestionsBox.querySelectorAll(".address-suggestion").forEach((button) => {
        button.addEventListener("click", async () => {
          const index = Number(button.getAttribute("data-index"));
          const prediction = suggestions[index]?.placePrediction;

          if (!prediction) return;

          const place = prediction.toPlace();

          await place.fetchFields({
            fields: ["id", "displayName", "formattedAddress", "location"],
          });

          const formattedAddress =
            place.formattedAddress ||
            place.displayName ||
            addressInput.value.trim() ||
            "";

          const location = place.location;

          const lat =
            typeof location?.lat === "function"
              ? location.lat()
              : location?.lat || "";

          const lng =
            typeof location?.lng === "function"
              ? location.lng()
              : location?.lng || "";

          lead.address = formattedAddress;
          lead.placeId = place.id || "";
          lead.lat = lat;
          lead.lng = lng;

          addressInput.value = formattedAddress;
          leadAddress.value = lead.address;
          leadPlaceId.value = lead.placeId;
          leadLat.value = String(lead.lat);
          leadLng.value = String(lead.lng);

          closeSuggestions();

          setAddressStatus(`Dirección seleccionada: ${lead.address}`, "is-ok");
        });
      });
    }

    try {
      if (!window["__dosllavesGoogleMapsConfigured"]) {
        setOptions({
          key: apiKey,
          v: "weekly",
          language: "es",
          region: "ES",
        });

        window["__dosllavesGoogleMapsConfigured"] = true;
      }

      const placesLibrary = await importLibrary("places");

      const AutocompleteSuggestion =
        placesLibrary.AutocompleteSuggestion ||
        google.maps.places.AutocompleteSuggestion;

      const AutocompleteSessionToken =
        placesLibrary.AutocompleteSessionToken ||
        google.maps.places.AutocompleteSessionToken;

      if (!AutocompleteSuggestion || !AutocompleteSessionToken) {
        throw new Error(
          "AutocompleteSuggestion no está disponible. Activa Places API (New) en el mismo proyecto de Google Cloud."
        );
      }

      let sessionToken = new AutocompleteSessionToken();
      let debounceTimer = null;

      setAddressStatus("Google Places conectado. Empieza a escribir la dirección.", "is-ok");

      addressInput.addEventListener("input", () => {
        const input = addressInput.value.trim();

        lead.address = input;
        leadAddress.value = input;
        lead.placeId = "";
        lead.lat = "";
        lead.lng = "";
        leadPlaceId.value = "";
        leadLat.value = "";
        leadLng.value = "";

        if (debounceTimer) clearTimeout(debounceTimer);

        if (input.length < 3) {
          closeSuggestions();
          setAddressStatus("Escribe al menos 3 caracteres para ver sugerencias.");
          return;
        }

        debounceTimer = setTimeout(async () => {
          try {
            const response =
              await AutocompleteSuggestion.fetchAutocompleteSuggestions({
                input,
                includedRegionCodes: ["es"],
                sessionToken,
              });

            renderSuggestions(response.suggestions || []);
          } catch (error) {
            console.error("[Google Places] Error sugerencias:", error);
            setAddressStatus(
              "No se han podido cargar sugerencias. Puedes escribir la dirección manualmente.",
              "is-error"
            );
          }
        }, 260);
      });

      document.addEventListener("click", (event) => {
        if (
          !addressInput.contains(event.target) &&
          !suggestionsBox.contains(event.target)
        ) {
          closeSuggestions();
        }
      });
    } catch (error) {
      console.error("[Google Places] Error real:", error, {
        hasApiKey: Boolean(apiKey),
        origin: window.location.origin,
        href: window.location.href,
      });

      const message =
        error instanceof Error
          ? error.message
          : "Error desconocido cargando Google Places.";

      setAddressStatus(
        `No se ha podido cargar Google Places: ${message}`,
        "is-error"
      );
    }
  }

  document.querySelectorAll("[data-next]").forEach((button) => {
    button.addEventListener("click", () => {
      const currentPanel = button.closest(".wizard-panel");
      const currentStep = Number(currentPanel?.getAttribute("data-step") || 1);
      const nextStep = button.getAttribute("data-next");

      if (!validateStep(currentStep)) return;
      setStep(nextStep);
    });
  });

  document.querySelectorAll("[data-prev]").forEach((button) => {
    button.addEventListener("click", () => {
      setStep(button.getAttribute("data-prev"));
    });
  });

  document.querySelectorAll("[data-choice-group]").forEach((group) => {
    group.querySelectorAll("button").forEach((button) => {
      button.addEventListener("click", () => {
        group.querySelectorAll("button").forEach((item) => item.classList.remove("is-active"));
        button.classList.add("is-active");

        const groupName = group.getAttribute("data-choice-group");
        const value = button.getAttribute("data-value");

        if (groupName === "situacion") {
          lead.situacion = value;
          leadSituacion.value = value;
        }

        if (groupName === "objetivo") {
          lead.objetivo = value;
          leadObjetivo.value = value;
        }
      });
    });
  });

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();

    const privacyAcceptedAt = document.querySelector("#lead-privacy-accepted-at");

    if (privacyAcceptedAt) {
      privacyAcceptedAt.value = new Date().toISOString();
    }

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    if (!validateStep(3)) return;

    const data = new FormData(form);

    if (data.get("website")) return;

    const payload = Object.fromEntries(data.entries());

    const runningInPreview =
      location.hostname.includes("localhost") ||
      location.hostname.includes("github.dev") ||
      location.hostname.includes("app.github.dev");

    const endpoint = runningInPreview ? "" : "/wp-json/dosllaves/v1/lead";

    let sent = false;

    if (endpoint) {
      try {
        const response = await fetch(endpoint, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify(payload),
        });

        sent = response.ok;
      } catch (error) {
        sent = false;
      }
    }

    if (sent) {
      setStep("success");
      return;
    }

    const message = [
      "Hola, quiero una valoración para mi inmueble.",
      "",
      `Dirección: ${payload.address || ""}`,
      `Situación: ${payload.situacion || ""}`,
      `Objetivo: ${payload.objetivo || ""}`,
      `Nombre: ${payload.nombre || ""}`,
      `Teléfono: ${payload.telefono || ""}`,
      `Email: ${payload.email || ""}`,
      `Mensaje: ${payload.mensaje || ""}`,
    ].join("\n");

    window.open(`https://wa.me/34623512885?text=${encodeURIComponent(message)}`, "_blank");
  });

  initGoogleAutocomplete();
</script>

<style>
  .lead-wizard-section {
    position: relative;
    background:
      radial-gradient(circle at 84% 12%, rgba(92, 242, 194, 0.14), transparent 30%),
      linear-gradient(180deg, #ffffff 0%, var(--primary-light) 100%);
    border-top: 1px solid rgba(6, 55, 126, 0.08);
    border-bottom: 1px solid rgba(6, 55, 126, 0.08);
  }

  .lead-wizard-header {
    display: grid;
    justify-items: center;
    gap: 14px;
    max-width: 820px;
    margin-inline: auto;
    text-align: center;
  }

  .lead-wizard-header p {
    max-width: 700px;
    color: var(--muted);
    font-size: 17px;
    line-height: 1.7;
  }

  .lead-wizard {
    display: grid;
    grid-template-columns: 260px minmax(0, 1fr);
    gap: 26px;
    margin-top: 44px;
    padding: 18px;
    border-radius: 34px;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(6, 55, 126, 0.12);
    box-shadow: 0 30px 90px rgba(6, 55, 126, 0.14);
    backdrop-filter: blur(16px);
  }

  .wizard-sidebar {
    position: relative;
    display: grid;
    align-content: start;
    gap: 18px;
    padding: 28px;
    border-radius: 26px;
    background:
      radial-gradient(circle at 80% 12%, rgba(92, 242, 194, 0.18), transparent 32%),
      linear-gradient(135deg, var(--primary) 0%, #084aa7 58%, var(--primary-dark) 100%);
    color: white;
    overflow: hidden;
  }

  .wizard-progress-rail {
    position: absolute;
    top: 58px;
    bottom: 46px;
    left: 48px;
    width: 3px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.14);
    overflow: hidden;
    z-index: 0;
  }

  .wizard-progress-bar {
    display: block;
    width: 100%;
    height: 100%;
    background: var(--accent);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 0.35s ease;
  }

  .wizard-step-label {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 48px 1fr;
    align-items: center;
    gap: 14px;
    min-height: 48px;
    opacity: 0.72;
  }

  .wizard-step-dot {
    width: 48px;
    height: 48px;
    display: grid;
    place-items: center;
    border-radius: 16px;
    background: #1d59ad;
    color: rgba(255, 255, 255, 0.78);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow:
      0 0 0 6px rgba(9, 57, 128, 1),
      0 10px 28px rgba(4, 29, 67, 0.18);
    font-weight: 900;
  }

  .wizard-step-label strong {
    font-size: 15px;
    font-weight: 800;
    color: rgba(255, 255, 255, 0.8);
  }

  .wizard-step-label.is-active,
  .wizard-step-label.is-complete {
    opacity: 1;
  }

  .wizard-step-label.is-active .wizard-step-dot,
  .wizard-step-label.is-complete .wizard-step-dot {
    background: var(--accent);
    color: var(--primary-dark);
    box-shadow:
      0 0 0 6px rgba(9, 57, 128, 1),
      0 14px 34px rgba(4, 29, 67, 0.22);
  }

  .wizard-step-label.is-active strong,
  .wizard-step-label.is-complete strong {
    color: white;
  }

  .wizard-form {
    min-height: 610px;
    padding: clamp(24px, 4vw, 42px);
    border-radius: 28px;
    background: white;
  }

  .wizard-panel {
    display: none;
    gap: 24px;
  }

  .wizard-panel.is-active {
    display: grid;
  }

  .wizard-panel-head {
    display: grid;
    gap: 10px;
  }

  .wizard-panel-head > span {
    width: max-content;
