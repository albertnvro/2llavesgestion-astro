/* =========================================================
   Gestión integral del alquiler — CRO + SEO landing
   ========================================================= */

:root {
  --gil-blue: #06377e;
  --gil-blue-2: #0b4fb3;
  --gil-ink: #07111f;
  --gil-muted: #627086;
  --gil-soft: #f4f7fb;
  --gil-line: rgba(7, 17, 31, 0.12);
  --gil-mint: #5cf2c2;
  --gil-white: #ffffff;
}

.gil-page,
.gil-page * {
  box-sizing: border-box;
}

.gil-page {
  background: var(--gil-white);
  color: var(--gil-ink);
}

.gil-hero {
  position: relative;
  min-height: 900px;
  display: flex;
  align-items: center;
  padding: 190px 0 110px;
  overflow: hidden;
  background:
    radial-gradient(circle at 80% 14%, rgba(92, 242, 194, 0.12), transparent 32%),
    linear-gradient(180deg, #ffffff 0%, #f4f7fb 100%);
}

.gil-hero::before {
  content: "";
  position: absolute;
  inset: 0;
  background:
    linear-gradient(90deg, rgba(6, 55, 126, 0.045) 1px, transparent 1px),
    linear-gradient(rgba(6, 55, 126, 0.045) 1px, transparent 1px);
  background-size: 72px 72px;
  mask-image: linear-gradient(180deg, black, transparent 72%);
  pointer-events: none;
}

.gil-hero-grid {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: minmax(0, 0.95fr) minmax(420px, 1.05fr);
  gap: clamp(46px, 7vw, 96px);
  align-items: center;
}

.gil-hero-copy {
  display: grid;
  gap: 22px;
}

.gil-breadcrumb {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  color: #7b8596;
  font-size: 13px;
  font-weight: 600;
}

.gil-breadcrumb a {
  color: var(--gil-blue);
  text-decoration: none;
}

.gil-breadcrumb strong {
  color: var(--gil-ink);
}

.gil-kicker {
  width: max-content;
  display: inline-flex;
  padding: 8px 11px;
  border-radius: 999px;
  background: var(--gil-blue);
  color: white;
  font-size: 13px;
  line-height: 1;
  font-weight: 750;
  letter-spacing: -0.01em;
}

.gil-kicker.dark {
  color: var(--gil-blue);
  background: #eef5ff;
}

.gil-hero h1 {
  max-width: 820px;
  margin: 0;
  color: var(--gil-ink);
  font-size: clamp(46px, 6vw, 82px);
  line-height: 0.96;
  letter-spacing: -0.065em;
  font-weight: 800;
}

.gil-lead {
  max-width: 690px;
  margin: 0;
  color: var(--gil-muted);
  font-size: clamp(17px, 1.4vw, 21px);
  line-height: 1.7;
  font-weight: 450;
}

.gil-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.gil-btn {
  min-height: 52px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 20px;
  border-radius: 999px;
  text-decoration: none;
  font-weight: 750;
  transition: transform 0.22s ease, box-shadow 0.22s ease;
}

.gil-btn:hover {
  transform: translateY(-2px);
}

.gil-btn-primary {
  color: white;
  background: var(--gil-ink);
  box-shadow: 0 18px 42px rgba(7, 17, 31, 0.18);
}

.gil-btn-secondary {
  color: var(--gil-blue);
  background: #eef5ff;
  border: 1px solid rgba(6, 55, 126, 0.12);
}

.gil-proof {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.gil-proof span {
  padding: 8px 10px;
  border-radius: 999px;
  color: #435168;
  background: white;
  border: 1px solid var(--gil-line);
  font-size: 13px;
  font-weight: 650;
}

.gil-hero-visual {
  position: relative;
  min-height: 580px;
}

.gil-photo {
  position: absolute;
  inset: 0 0 70px 52px;
  overflow: hidden;
  border-radius: 24px;
  background: #d9dee7;
  box-shadow: 0 38px 100px rgba(7, 17, 31, 0.20);
}

.gil-photo::after {
  content: "";
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, transparent 48%, rgba(7, 17, 31, 0.45)),
    radial-gradient(circle at 76% 12%, rgba(255, 255, 255, 0.24), transparent 36%);
}

.gil-photo img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.gil-ops-card {
  position: absolute;
  left: 0;
  bottom: 0;
  width: min(390px, 82%);
  display: grid;
  gap: 14px;
  padding: 22px;
  border-radius: 20px;
  background: rgba(255, 255, 255, 0.96);
  border: 1px solid rgba(7, 17, 31, 0.10);
  box-shadow: 0 28px 70px rgba(7, 17, 31, 0.18);
  backdrop-filter: blur(18px);
}

.gil-ops-card > span {
  color: var(--gil-blue);
  font-size: 13px;
  font-weight: 750;
}

.gil-ops-line {
  position: relative;
  display: grid;
  grid-template-columns: 18px minmax(0, 1fr);
  column-gap: 11px;
}

.gil-ops-line:not(:last-child)::after {
  content: "";
  position: absolute;
  left: 8px;
  top: 23px;
  bottom: -14px;
  width: 2px;
  background: #d8e4f5;
}

.gil-ops-line i {
  position: relative;
  z-index: 1;
  width: 18px;
  height: 18px;
  margin-top: 2px;
  border-radius: 999px;
  background: var(--gil-blue);
  box-shadow: 0 0 0 5px #eef5ff;
  animation: gilPulse 2.4s ease-in-out infinite;
}

.gil-ops-line strong {
  color: var(--gil-ink);
  font-size: 15px;
  line-height: 1.2;
}

.gil-ops-line small {
  grid-column: 2;
  color: var(--gil-muted);
  font-size: 13px;
  line-height: 1.4;
}

.gil-status-card {
  position: absolute;
  right: 20px;
  top: 30px;
  display: grid;
  gap: 3px;
  min-width: 210px;
  padding: 16px;
  border-radius: 16px;
  color: white;
  background: var(--gil-ink);
  box-shadow: 0 20px 54px rgba(7, 17, 31, 0.22);
  animation: gilFloat 4.5s ease-in-out infinite;
}

.gil-status-card small {
  color: var(--gil-mint);
  font-weight: 700;
}

.gil-status-card strong {
  font-size: 17px;
  line-height: 1.18;
}

.gil-strip {
  background: var(--gil-ink);
  color: white;
}

.gil-strip-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.gil-strip-grid div {
  display: grid;
  gap: 6px;
  padding: 28px;
  border-right: 1px solid rgba(255,255,255,.12);
}

.gil-strip-grid div:last-child {
  border-right: 0;
}

.gil-strip-grid strong {
  color: white;
  font-size: 18px;
}

.gil-strip-grid span {
  color: rgba(255,255,255,.72);
  line-height: 1.55;
}

.gil-section {
  padding: clamp(78px, 7vw, 118px) 0;
}

.gil-two {
  display: grid;
  grid-template-columns: minmax(0, 0.88fr) minmax(420px, 1.12fr);
  gap: clamp(42px, 7vw, 90px);
  align-items: start;
}

.gil-two h2,
.gil-heading h2,
.gil-process-copy h2,
.gil-proof-section h2,
.gil-faq h2,
.gil-final h2 {
  margin: 0;
  color: var(--gil-ink);
  font-size: clamp(34px, 4.4vw, 60px);
  line-height: 1.04;
  letter-spacing: -0.055em;
  font-weight: 800;
}

.gil-text-block p,
.gil-heading p,
.gil-process-copy p,
.gil-proof-section p,
.gil-final p {
  margin: 0;
  color: var(--gil-muted);
  font-size: 17px;
  line-height: 1.75;
}

.gil-heading {
  display: grid;
  justify-items: center;
  gap: 14px;
  max-width: 820px;
  text-align: center;
}

.gil-heading p {
  max-width: 680px;
}

.gil-compare-section {
  background: var(--gil-soft);
}

.gil-comparison-wrap {
  margin-top: 42px;
  overflow-x: auto;
}

.gil-comparison-table {
  width: 100%;
  min-width: 840px;
  border-collapse: separate;
  border-spacing: 0;
  overflow: hidden;
  border-radius: 20px;
  background: white;
  border: 1px solid var(--gil-line);
  box-shadow: 0 18px 50px rgba(7, 17, 31, 0.08);
}

.gil-comparison-table th,
.gil-comparison-table td {
  padding: 18px;
  text-align: left;
  border-bottom: 1px solid rgba(7, 17, 31, 0.08);
  vertical-align: top;
}

.gil-comparison-table th {
  color: var(--gil-ink);
  font-size: 14px;
  font-weight: 780;
  background: #f8fbff;
}

.gil-comparison-table td {
  color: var(--gil-muted);
  line-height: 1.45;
  font-weight: 520;
}

.gil-comparison-table td:first-child {
  color: var(--gil-ink);
  font-weight: 780;
}

.gil-comparison-table th:last-child,
.gil-comparison-table td:last-child {
  color: white;
  background: var(--gil-blue);
}

.gil-comparison-table tbody tr:last-child td {
  border-bottom: 0;
}

.gil-light {
  background: white;
}

.gil-modules {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18px;
  margin-top: 44px;
}

.gil-module {
  display: grid;
  gap: 13px;
  min-height: 230px;
  padding: 26px;
  border-radius: 20px;
  background: var(--gil-soft);
  border: 1px solid var(--gil-line);
  transition: transform 0.22s ease, box-shadow 0.22s ease;
}

.gil-module:hover {
  transform: translateY(-4px);
  box-shadow: 0 22px 60px rgba(7,17,31,.09);
}

.gil-module span {
  width: 44px;
  height: 44px;
  border-radius: 14px;
  background:
    radial-gradient(circle at 72% 18%, rgba(255,255,255,.9), transparent 36%),
    linear-gradient(135deg, #eaf3ff, #d7e8ff);
  border: 1px solid rgba(6,55,126,.10);
}

.gil-module h3 {
  margin: 0;
  color: var(--gil-ink);
  font-size: 22px;
  line-height: 1.12;
  letter-spacing: -0.035em;
}

.gil-module p {
  margin: 0;
  color: var(--gil-muted);
  line-height: 1.65;
}

.gil-process-section {
  background: var(--gil-soft);
}

.gil-process-grid {
  display: grid;
  grid-template-columns: minmax(0, 0.88fr) minmax(460px, 1.12fr);
  gap: clamp(42px, 7vw, 90px);
  align-items: start;
}

.gil-process-copy {
  position: sticky;
  top: 150px;
  display: grid;
  gap: 16px;
}

.gil-process {
  display: grid;
  gap: 14px;
}

.gil-process article {
  display: grid;
  grid-template-columns: 54px minmax(0, 1fr);
  gap: 18px;
  padding: 22px;
  border-radius: 18px;
  background: white;
  border: 1px solid var(--gil-line);
}

.gil-process span {
  width: 44px;
  height: 44px;
  display: grid;
  place-items: center;
  border-radius: 14px;
  color: white;
  background: var(--gil-blue);
  font-weight: 750;
}

.gil-process h3 {
  margin: 0 0 6px;
  color: var(--gil-ink);
  font-size: 20px;
  letter-spacing: -0.025em;
}

.gil-process p {
  margin: 0;
  color: var(--gil-muted);
  line-height: 1.65;
}

.gil-personas {
  background: white;
}

.gil-persona-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 18px;
  margin-top: 42px;
}

.gil-persona-grid article {
  padding: 24px;
  border-radius: 18px;
  border: 1px solid var(--gil-line);
  background: var(--gil-soft);
}

.gil-persona-grid strong {
  display: block;
  margin-bottom: 8px;
  color: var(--gil-ink);
  font-size: 20px;
  letter-spacing: -0.03em;
}

.gil-persona-grid p {
  margin: 0;
  color: var(--gil-muted);
  line-height: 1.65;
}

.gil-proof-section {
  color: white;
  background:
    radial-gradient(circle at 84% 14%, rgba(92, 242, 194, 0.16), transparent 30%),
    linear-gradient(135deg, var(--gil-blue) 0%, #0a438f 52%, var(--gil-ink) 100%);
}

.gil-proof-section h2,
.gil-proof-section p {
  color: white;
}

.gil-proof-grid {
  display: grid;
  grid-template-columns: minmax(0, 0.92fr) minmax(360px, 1.08fr);
  gap: clamp(40px, 7vw, 88px);
  align-items: center;
}

.gil-proof-grid > div:first-child {
  display: grid;
  gap: 16px;
}

.gil-proof-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.gil-proof-list span {
  padding: 10px 13px;
  border-radius: 999px;
  color: rgba(255, 255, 255, 0.92);
  background: rgba(255, 255, 255, 0.12);
  border: 1px solid rgba(255, 255, 255, 0.16);
  font-weight: 650;
}

.gil-faq {
  background: white;
}

.gil-faq-grid {
  display: grid;
  grid-template-columns: minmax(0, 0.88fr) minmax(420px, 1.12fr);
  gap: clamp(42px, 7vw, 90px);
  align-items: start;
}

.gil-accordion {
  display: grid;
  gap: 12px;
}

.gil-accordion details {
  overflow: hidden;
  border-radius: 16px;
  background: var(--gil-soft);
  border: 1px solid var(--gil-line);
}

.gil-accordion summary {
  position: relative;
  padding: 20px 52px 20px 20px;
  cursor: pointer;
  color: var(--gil-ink);
  font-weight: 700;
  list-style: none;
}

.gil-accordion summary::-webkit-details-marker {
  display: none;
}

.gil-accordion summary::after {
  content: "+";
  position: absolute;
  right: 20px;
  top: 50%;
  color: var(--gil-blue);
  font-size: 24px;
  font-weight: 700;
  transform: translateY(-50%);
}

.gil-accordion details[open] summary::after {
  content: "–";
}

.gil-accordion p {
  margin: 0;
  padding: 0 20px 20px;
  color: var(--gil-muted);
  line-height: 1.7;
}

.gil-final {
  padding: clamp(78px, 7vw, 118px) 0;
  background:
    radial-gradient(circle at 84% 14%, rgba(92, 242, 194, 0.12), transparent 30%),
    linear-gradient(180deg, #ffffff 0%, #eef5ff 100%);
}

.gil-final-card {
  display: grid;
  justify-items: center;
  gap: 18px;
  max-width: 900px;
  padding: clamp(34px, 5vw, 62px);
  border-radius: 22px;
  text-align: center;
  color: white;
  background: var(--gil-ink);
  box-shadow: 0 34px 100px rgba(7, 17, 31, 0.22);
}

.gil-final h2,
.gil-final p {
  color: white;
}

.gil-final p {
  max-width: 650px;
  color: rgba(255, 255, 255, 0.78);
}

.gil-conversion-bar {
  position: fixed;
  left: 50%;
  bottom: 22px;
  z-index: 9000;
  width: min(520px, calc(100vw - 28px));
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 10px 10px 10px 18px;
  border-radius: 999px;
  background: rgba(7, 17, 31, 0.94);
  color: white;
  box-shadow: 0 24px 70px rgba(7, 17, 31, 0.30);
  backdrop-filter: blur(16px);
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transform: translateX(-50%) translateY(16px);
  transition: opacity .22s ease, visibility .22s ease, transform .22s ease;
}

.gil-conversion-bar.is-visible {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
  transform: translateX(-50%) translateY(0);
}

.gil-conversion-bar span {
  font-weight: 700;
  font-size: 14px;
}

.gil-conversion-bar a {
  min-height: 42px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 15px;
  border-radius: 999px;
  color: var(--gil-ink);
  background: var(--gil-mint);
  text-decoration: none;
  font-weight: 750;
}

[data-gil-reveal] {
  opacity: 0;
  transform: translateY(28px);
  transition: opacity 0.75s ease, transform 0.75s ease;
}

[data-gil-reveal].is-visible {
  opacity: 1;
  transform: translateY(0);
}

@keyframes gilFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-9px); }
}

@keyframes gilPulse {
  0%, 100% { box-shadow: 0 0 0 5px #eef5ff; }
  50% { box-shadow: 0 0 0 8px rgba(6, 55, 126, 0.08); }
}

@media (max-width: 1100px) {
  .gil-hero-grid,
  .gil-two,
  .gil-process-grid,
  .gil-proof-grid,
  .gil-faq-grid {
    grid-template-columns: 1fr;
  }

  .gil-process-copy {
    position: relative;
    top: auto;
  }

  .gil-modules {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .gil-persona-grid,
  .gil-strip-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .gil-hero-visual {
    min-height: 560px;
  }
}

@media (max-width: 640px) {
  .gil-hero {
    min-height: auto;
    padding-top: 140px;
  }

  .gil-hero h1 {
    font-size: 43px;
  }

  .gil-actions {
    flex-direction: column;
  }

  .gil-btn {
    width: 100%;
  }

  .gil-modules,
  .gil-persona-grid,
  .gil-strip-grid {
    grid-template-columns: 1fr;
  }

  .gil-strip-grid div {
    border-right: 0;
    border-bottom: 1px solid rgba(255,255,255,.12);
  }

  .gil-strip-grid div:last-child {
    border-bottom: 0;
  }

  .gil-hero-visual {
    min-height: auto;
    display: grid;
    gap: 14px;
  }

  .gil-photo,
  .gil-ops-card,
  .gil-status-card {
    position: relative;
    inset: auto;
    width: 100%;
  }

  .gil-photo {
    height: 380px;
  }

  .gil-process article {
    grid-template-columns: 1fr;
  }

  .gil-conversion-bar {
    bottom: 12px;
    border-radius: 18px;
    align-items: stretch;
    flex-direction: column;
    padding: 14px;
  }

  .gil-conversion-bar a {
    width: 100%;
  }
}

/* =========================================================
   Iconos y CTAs intermedios — CRO polish
   ========================================================= */

.gil-module span {
  width: 48px;
  height: 48px;
  display: grid;
  place-items: center;
  border-radius: 15px;
  color: var(--gil-blue);
  background:
    radial-gradient(circle at 72% 18%, rgba(255,255,255,.9), transparent 36%),
    linear-gradient(135deg, #eaf3ff, #d7e8ff);
  border: 1px solid rgba(6,55,126,.10);
  box-shadow: 0 12px 28px rgba(6,55,126,.07);
}

.gil-module span svg {
  width: 24px;
  height: 24px;
  display: block;
  stroke: currentColor;
}

.gil-module:nth-child(1) span {
  color: #06377e;
}

.gil-module:nth-child(2) span {
  color: #0b4fb3;
  background:
    radial-gradient(circle at 72% 18%, rgba(255,255,255,.9), transparent 36%),
    linear-gradient(135deg, #eef5ff, #dbeafe);
}

.gil-module:nth-child(3) span {
  color: #92400e;
  background:
    radial-gradient(circle at 72% 18%, rgba(255,255,255,.9), transparent 36%),
    linear-gradient(135deg, #fff7ed, #ffedd5);
}

.gil-module:nth-child(4) span {
  color: #0f766e;
  background:
    radial-gradient(circle at 72% 18%, rgba(255,255,255,.9), transparent 36%),
    linear-gradient(135deg, #ecfdf5, #ccfbf1);
}

.gil-module:nth-child(5) span {
  color: #4338ca;
  background:
    radial-gradient(circle at 72% 18%, rgba(255,255,255,.9), transparent 36%),
    linear-gradient(135deg, #eef2ff, #e0e7ff);
}

.gil-module:nth-child(6) span {
  color: #07111f;
  background:
    radial-gradient(circle at 72% 18%, rgba(255,255,255,.85), transparent 36%),
    linear-gradient(135deg, #f8fafc, #e2e8f0);
}

.gil-inline-cta {
  margin-top: 34px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 22px;
  padding: 22px;
  border-radius: 20px;
  border: 1px solid rgba(7,17,31,.10);
  box-shadow: 0 18px 50px rgba(7,17,31,.08);
}

.gil-inline-cta > div:first-child {
  display: grid;
  gap: 5px;
}

.gil-inline-cta strong {
  color: inherit;
  font-size: clamp(20px, 2vw, 28px);
  line-height: 1.12;
  letter-spacing: -.04em;
}

.gil-inline-cta p {
  margin: 0;
  color: inherit;
  opacity: .76;
  line-height: 1.55;
}

.gil-compare-cta {
  background: #ffffff;
  color: var(--gil-ink);
}

.gil-modules-cta {
  background:
    radial-gradient(circle at 90% 12%, rgba(92,242,194,.12), transparent 30%),
    linear-gradient(135deg, var(--gil-blue) 0%, #0a438f 52%, var(--gil-ink) 100%);
  color: #ffffff;
  border-color: rgba(255,255,255,.16);
}

.gil-personas-cta {
  background: var(--gil-ink);
  color: #ffffff;
  border-color: rgba(255,255,255,.12);
}

.gil-inline-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  flex: 0 0 auto;
}

.gil-small-btn {
  min-height: 44px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 15px;
  border-radius: 999px;
  text-decoration: none;
  font-weight: 750;
  white-space: nowrap;
  transition: transform .18s ease, box-shadow .18s ease;
}

.gil-small-btn:hover {
  transform: translateY(-2px);
}

.gil-small-btn-primary {
  color: #ffffff;
  background: var(--gil-ink);
  box-shadow: 0 14px 34px rgba(7,17,31,.16);
}

.gil-modules-cta .gil-small-btn-primary,
.gil-personas-cta .gil-small-btn-primary {
  color: var(--gil-ink);
  background: var(--gil-mint);
  box-shadow: none;
}

.gil-small-btn-secondary {
  color: var(--gil-blue);
  background: #eef5ff;
  border: 1px solid rgba(6,55,126,.12);
}

.gil-text-cta {
  width: max-content;
  min-height: 46px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 4px;
  padding: 0 16px;
  border-radius: 999px;
  color: #ffffff;
  background: var(--gil-ink);
  text-decoration: none;
  font-weight: 750;
  box-shadow: 0 14px 34px rgba(7,17,31,.14);
}

@media (max-width: 760px) {
  .gil-inline-cta {
    align-items: flex-start;
    flex-direction: column;
  }

  .gil-inline-actions,
  .gil-small-btn,
  .gil-text-cta {
    width: 100%;
  }
}

/* =========================================================
   CTAs visibles — CRO layer
   ========================================================= */

.gil-cta-band {
  position: relative;
  z-index: 2;
  padding: 34px 0;
  background: #ffffff;
}

.gil-cta-band-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 28px;
  padding: clamp(24px, 3vw, 34px);
  border-radius: 22px;
  background: #ffffff;
  border: 1px solid rgba(7, 17, 31, 0.10);
  box-shadow: 0 22px 64px rgba(7, 17, 31, 0.10);
}

.gil-cta-band-inner > div:first-child {
  display: grid;
  gap: 7px;
}

.gil-cta-band span {
  width: max-content;
  display: inline-flex;
  padding: 7px 10px;
  border-radius: 999px;
  color: var(--gil-blue, #06377e);
  background: #eef5ff;
  font-size: 13px;
  line-height: 1;
  font-weight: 800;
}

.gil-cta-band strong {
  display: block;
  max-width: 760px;
  color: var(--gil-ink, #07111f);
  font-size: clamp(24px, 3vw, 38px);
  line-height: 1.06;
  letter-spacing: -0.045em;
  font-weight: 800;
}

.gil-cta-band p {
  margin: 0;
  max-width: 660px;
  color: var(--gil-muted, #627086);
  font-size: 16px;
  line-height: 1.65;
}

.gil-cta-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  flex: 0 0 auto;
}

.gil-cta-primary,
.gil-cta-secondary {
  min-height: 48px;
  display: inline-flex !important;
  align-items: center;
  justify-content: center;
  padding: 0 18px;
  border-radius: 999px;
  text-decoration: none !important;
  font-weight: 800;
  white-space: nowrap;
  transition: transform 0.18s ease, box-shadow 0.18s ease;
}

.gil-cta-primary:hover,
.gil-cta-secondary:hover {
  transform: translateY(-2px);
}

.gil-cta-primary {
  color: #ffffff !important;
  background: var(--gil-ink, #07111f) !important;
  box-shadow: 0 14px 34px rgba(7, 17, 31, 0.18);
}

.gil-cta-secondary {
  color: var(--gil-blue, #06377e) !important;
  background: #eef5ff !important;
  border: 1px solid rgba(6, 55, 126, 0.14);
}

.gil-cta-dark {
  background:
    radial-gradient(circle at 84% 14%, rgba(92, 242, 194, 0.12), transparent 30%),
    linear-gradient(135deg, var(--gil-blue, #06377e) 0%, #0a438f 52%, var(--gil-ink, #07111f) 100%);
}

.gil-cta-dark .gil-cta-band-inner {
  color: #ffffff;
  background: rgba(255, 255, 255, 0.08);
  border-color: rgba(255, 255, 255, 0.16);
  box-shadow: none;
}

.gil-cta-dark span {
  color: var(--gil-mint, #5cf2c2);
  background: rgba(255, 255, 255, 0.13);
}

.gil-cta-dark strong {
  color: #ffffff;
}

.gil-cta-dark p {
  color: rgba(255, 255, 255, 0.76);
}

.gil-cta-dark .gil-cta-primary {
  color: var(--gil-ink, #07111f) !important;
  background: var(--gil-mint, #5cf2c2) !important;
  box-shadow: none;
}

.gil-sticky-cta {
  position: fixed;
  left: 50%;
  bottom: 22px;
  z-index: 9000;
  width: min(520px, calc(100vw - 28px));
  display: flex !important;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 10px 10px 10px 18px;
  border-radius: 999px;
  background: rgba(7, 17, 31, 0.94);
  color: #ffffff;
  box-shadow: 0 24px 70px rgba(7, 17, 31, 0.30);
  backdrop-filter: blur(16px);
  transform: translateX(-50%);
}

.gil-sticky-cta span {
  font-weight: 750;
  font-size: 14px;
}

.gil-sticky-cta a {
  min-height: 42px;
  display: inline-flex !important;
  align-items: center;
  justify-content: center;
  padding: 0 15px;
  border-radius: 999px;
  color: var(--gil-ink, #07111f) !important;
  background: var(--gil-mint, #5cf2c2) !important;
  text-decoration: none !important;
  font-weight: 800;
}

@media (max-width: 760px) {
  .gil-cta-band-inner {
    align-items: flex-start;
    flex-direction: column;
  }

  .gil-cta-actions,
  .gil-cta-primary,
  .gil-cta-secondary {
    width: 100%;
  }

  .gil-sticky-cta {
    bottom: 12px;
    align-items: stretch;
    flex-direction: column;
    border-radius: 18px;
    padding: 14px;
  }

  .gil-sticky-cta a {
    width: 100%;
  }
}
